<Window x:Class="GuaranteeManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:nav="clr-namespace:GuaranteeManager.Themes.Base"
        mc:Ignorable="d"
        Title="نظام الضمانات البنكية | مستشفى الملك فيصل التخصصي ومركز الأبحاث"
        Width="1560"
        Height="940"
        MinWidth="1180"
        MinHeight="860"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        SizeChanged="MainWindow_SizeChanged"
        PreviewKeyDown="MainWindow_PreviewKeyDown">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="Shell.ToolbarTile" TargetType="Border" BasedOn="{StaticResource Tile.Neutral}">
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style x:Key="Shell.RailSection" TargetType="Border" BasedOn="{StaticResource Card.Compact}">
            <Setter Property="Margin" Value="8,0,8,8"/>
            <Setter Property="Padding" Value="0,12"/>
        </Style>
        <Style x:Key="Shell.SideSheetHeader" TargetType="Border" BasedOn="{StaticResource Panel.Advisor}">
            <Setter Property="Padding" Value="{StaticResource Space_Padding_SideSheet}"/>
        </Style>
        <Style x:Key="Shell.FooterTile" TargetType="Border" BasedOn="{StaticResource Tile.Neutral}">
            <Setter Property="Padding" Value="10,4"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource Surface_Bg_Light}" FlowDirection="RightToLeft">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/> <!-- Row 0: Title Bar -->
            <RowDefinition Height="72"/> <!-- Row 1: Global Fixed Header -->
            <RowDefinition Height="*"/>  <!-- Row 2: Main Workspace -->
            <RowDefinition Height="44"/> <!-- Row 3: Footer -->
        </Grid.RowDefinitions>

        <!-- [Row 0] Title Bar -->
        <Border Grid.Row="0"
                Background="{StaticResource Brand_Emerald}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Style="{StaticResource Button.TitleBar}" Click="CloseWindow_Click" ToolTip="إغلاق">
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource Text_OnBrand}"
                                   FontSize="10"/>
                    </Button>
                    <Button x:Name="BtnMaximizeRestoreWindow" Style="{StaticResource Button.TitleBar}" Click="MaximizeRestoreWindow_Click" ToolTip="تكبير أو استعادة">
                        <TextBlock Text="&#xE922;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource Text_OnBrand}"
                                   FontSize="10"/>
                    </Button>
                    <Button Style="{StaticResource Button.TitleBar}" Click="MinimizeWindow_Click" ToolTip="تصغير">
                        <TextBlock Text="&#xE921;"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{StaticResource Text_OnBrand}"
                                   FontSize="10"/>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" FlowDirection="RightToLeft" VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False">
                    <Image Source="pack://application:,,,/Assets/KFSHRC/kfshrc-favicon-mono.png" Width="16" Height="16"/>
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Text_OnBrand}" FontSize="11" FontWeight="SemiBold" Text="{Binding Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- [Row 1] Global Fixed Header (Detached from Workspace) -->
        <Border Grid.Row="1"
                Background="{StaticResource Surface_Header}"
                BorderBrush="{StaticResource Surface_Border}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="HeaderSidebarColumn" Width="232"/> <!-- Rail for Sidebar Consistency -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar Upper Bound (Logo Section) -->
                <Border Grid.Column="0"
                        Background="{StaticResource Neutral_White}"
                        BorderBrush="{StaticResource Surface_Border}"
                        BorderThickness="0,0,1,0"
                        Padding="16,0">
                    <StackPanel VerticalAlignment="Center" FlowDirection="LeftToRight" HorizontalAlignment="Center">
                        <Image Source="pack://application:,,,/Assets/KFSHRC/logo-cropped-mono.png" Height="32" />
                    </StackPanel>
                </Border>

                <!-- Global Toolbar Area -->
                <Border Grid.Column="1" Padding="8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/> <!-- Title (Right in RTL) -->
                            <ColumnDefinition Width="12"/>  <!-- Gap -->
                            <ColumnDefinition Width="*"/>   <!-- Search -->
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource Shell.ToolbarTile}"
                                VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Text_Caption}" Text="مساحة العمل الحالية"/>
                                <TextBlock x:Name="TxtCurrentScreenHeader"
                                           Margin="0,2,0,0"
                                           Style="{StaticResource Text_H2}"
                                           FontSize="18"
                                           Text="{Binding CurrentWorkspaceName}"/>
                                <TextBlock x:Name="TxtCurrentScreenDescription"
                                           Style="{StaticResource Text_Muted}"
                                           Margin="0,2,0,0"
                                           Text="{Binding CurrentWorkspaceDescription}"
                                           ToolTip="{Binding CurrentWorkspaceDescription}"/>
                            </StackPanel>
                        </Border>

                        <Border Name="SearchBox"
                                Grid.Column="2"
                                Style="{StaticResource Shell.ToolbarTile}"
                                Background="{StaticResource Neutral_White}"
                                Padding="0"
                                Height="40"
                                Margin="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                FlowDirection="LeftToRight">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Width="28"
                                        Height="28"
                                        MinWidth="0"
                                        MinHeight="0"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Focusable="False"
                                        Command="{Binding SearchCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Path Data="{StaticResource Icon_Search}"
                                          Stroke="{StaticResource Brush_Text_Muted}"
                                          StrokeThickness="1.5"
                                          Width="16" Height="16"
                                          Stretch="Uniform"/>
                                </Button>
                                <TextBox Grid.Column="1"
                                         x:Name="TxtUnifiedSearch"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="6,0,12,0"
                                         FlowDirection="RightToLeft"
                                         TextAlignment="Right"
                                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         KeyDown="TxtUnifiedSearch_KeyDown"
                                         VerticalContentAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- [Row 2] Main Workspace (Scrollable Content + Sidebar) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="WorkspaceSidebarColumn" Width="232"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Column 0: Sidebar Body -->
            <Border Grid.Column="0"
                    Background="{StaticResource Neutral_White}"
                    BorderBrush="{StaticResource Surface_Border}"
                    BorderThickness="0,0,1,0"
                    Padding="0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Shell.RailSection}">
                        <StackPanel Margin="0,4,0,0">
                            <TextBlock x:Name="TxtNavigationSection" Style="{StaticResource Text_Caption}" Margin="16,0,16,16" Text="التنقل"/>
                            <Button x:Name="BtnNavToday" Style="{StaticResource Button.Nav.V2}" Tag="Today" nav:Nav.IsActive="True" Command="{Binding NavigateCommand}" CommandParameter="Today" ToolTip="الرئيسية" Padding="24,0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" Data="{StaticResource Icon_Home}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Width="18" Height="18" VerticalAlignment="Center" Stretch="Uniform"/>
                                    <TextBlock x:Name="TxtNavTodayLabel" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Style="{StaticResource Text_Body}" Text="الرئيسية"/>
                                </Grid>
                            </Button>
                            <Button x:Name="BtnNavReception" Style="{StaticResource Button.Nav.V2}" Tag="Reception" Command="{Binding NavigateCommand}" CommandParameter="Reception" ToolTip="المتابعات" Padding="24,0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" Data="{StaticResource Icon_Add}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Width="18" Height="18" VerticalAlignment="Center" Stretch="Uniform"/>
                                    <TextBlock x:Name="TxtNavReceptionLabel" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Style="{StaticResource Text_Body}" Text="المتابعات"/>
                                </Grid>
                            </Button>
                            <Button x:Name="BtnNavPortfolio" Style="{StaticResource Button.Nav.V2}" Tag="Portfolio" Command="{Binding NavigateCommand}" CommandParameter="Portfolio" ToolTip="الضمانات" Padding="24,0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" Data="{StaticResource Icon_Portfolio}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Width="18" Height="18" VerticalAlignment="Center" Stretch="Uniform"/>
                                    <TextBlock x:Name="TxtNavPortfolioLabel" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Style="{StaticResource Text_Body}" Text="الضمانات"/>
                                </Grid>
                            </Button>
                            <Button x:Name="BtnNavBankRoom" Style="{StaticResource Button.Nav.V2}" Tag="BankRoom" Command="{Binding NavigateCommand}" CommandParameter="BankRoom" ToolTip="الطلبات" Padding="24,0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" Data="{StaticResource Icon_Requests}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Width="18" Height="18" VerticalAlignment="Center" Stretch="Uniform"/>
                                    <TextBlock x:Name="TxtNavBankRoomLabel" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Style="{StaticResource Text_Body}" Text="الطلبات"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Shell.RailSection}" Margin="8,0,8,0">
                        <StackPanel>
                            <TextBlock x:Name="TxtQuickAccessSection" Style="{StaticResource Text_Caption}" Margin="16,0,16,8" Text="وصول سريع"/>
                            <Button x:Name="BtnResumeLastFileSide" Style="{StaticResource Button.Nav}" Command="{Binding ResumeLastFileCommand}" IsEnabled="{Binding HasLastFile}" ToolTip="{Binding LastFileToolTip}" Padding="24,0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" Data="{StaticResource Icon_Requests}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Width="18" Height="18" VerticalAlignment="Center" Stretch="Uniform"/>
                                    <TextBlock x:Name="TxtResumeLastFileSideLabel" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Style="{StaticResource Text_Body}" Text="أكمل آخر عمل"/>
                                </Grid>
                            </Button>
                            <Button x:Name="BtnNavAdministration" Style="{StaticResource Button.Nav}" Tag="Administration" Command="{Binding NavigateCommand}" CommandParameter="Administration" ToolTip="الإعدادات" Padding="24,0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" Data="{StaticResource Icon_Settings}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Width="18" Height="18" VerticalAlignment="Center" Stretch="Uniform"/>
                                    <TextBlock x:Name="TxtNavAdministrationLabel" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Style="{StaticResource Text_Body}" Text="الإعدادات"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Column 1: Workspace Content (The Island) -->
            <Border Grid.Column="1" Padding="{DynamicResource Space_Shell_Outer}">
                <Grid>
                    <ContentControl x:Name="MainContentArea" Content="{Binding CurrentContent}" />
                    <Grid x:Name="ShellContentOverlayAnchor" Panel.ZIndex="50" Visibility="Collapsed">
                        <Border x:Name="SideSheetScrim" Background="{StaticResource Surface_Scrim}" MouseDown="SideSheetScrim_MouseDown"/>
                        <Border x:Name="SideSheetHost" Width="{DynamicResource Size_SideSheet_Width}" HorizontalAlignment="Right" Background="{StaticResource Surface_Card_White}" BorderBrush="{StaticResource Surface_Border}" BorderThickness="1,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <Border Style="{StaticResource Shell.SideSheetHeader}" BorderBrush="{StaticResource Surface_Border}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Style="{StaticResource Badge.Icon.Emphasis}">
                                                <Path Data="{StaticResource Icon_Geometry_Advisor}" Style="{StaticResource Path_SectionIcon}"/>
                                            </Border>
                                            <StackPanel>
                                                <TextBlock x:Name="TxtSideSheetTitle" Style="{StaticResource Text_H2}" Text="لوح جانبي"/>
                                                <TextBlock x:Name="TxtSideSheetSubtitle" Margin="0,4,0,0" Style="{StaticResource Text_Muted}" Text="يظهر هنا ملخص سياقي سريع."/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource Button.Subtle}" Click="CloseSideSheet_Click">
                                            <TextBlock Style="{StaticResource IconText.Regular}" Text="{StaticResource Glyph_Close}"/>
                                        </Button>
                                    </Grid>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ContentControl x:Name="SideSheetContentHost"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- [Row 3] Status Bar Footer -->
        <Border Grid.Row="3" Background="{StaticResource Surface_Card_White}" BorderBrush="{StaticResource Surface_Border}" BorderThickness="0,1,0,0" Padding="12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Shell.FooterTile}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse x:Name="StatusToneDot" Width="8" Height="8" Fill="{StaticResource Status_Info}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtStatusTone" Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center" Style="{StaticResource Text_Caption}" Text="معلومة"/>
                        <TextBlock x:Name="TxtStatusMessage" Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center" Style="{StaticResource Text_Muted}" Text="{Binding StatusMessage}"/>
                    </Grid>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource Shell.FooterTile}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource Text_Caption}" Foreground="{StaticResource Brush_Text_Muted}" Text="الإصدار v1.0.0"/>
                        <Rectangle Width="1" Height="12" Fill="{StaticResource Surface_Border}" Margin="12,0"/>
                        <TextBlock Style="{StaticResource Text_Caption}" Foreground="{StaticResource Status_Success}" Text="● متصل الآن"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
