<Application x:Class="GuaranteeManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/GuaranteeManager;component/IconsDictionary.xaml" />
                <ResourceDictionary Source="pack://application:,,,/GuaranteeManager;component/Presentation/Themes/Colors.xaml" />
                <ResourceDictionary Source="pack://application:,,,/GuaranteeManager;component/Presentation/Themes/Effects.xaml" />
                <ResourceDictionary Source="pack://application:,,,/GuaranteeManager;component/Presentation/Themes/Converters.xaml" />
                <ResourceDictionary Source="pack://application:,,,/GuaranteeManager;component/Presentation/Themes/ScrollBars.xaml" />
                <ResourceDictionary Source="pack://application:,,,/GuaranteeManager;component/Presentation/Themes/Buttons.xaml" />
                <ResourceDictionary Source="pack://application:,,,/GuaranteeManager;component/Presentation/Themes/Inputs.xaml" />
                <ResourceDictionary Source="pack://application:,,,/GuaranteeManager;component/Presentation/Themes/Cards.xaml" />
                <ResourceDictionary Source="pack://application:,,,/GuaranteeManager;component/Presentation/Themes/Typography.xaml" />
                <ResourceDictionary Source="pack://application:,,,/GuaranteeManager;component/Presentation/Themes/Tables.xaml" />
                <ResourceDictionary Source="pack://application:,,,/GuaranteeManager;component/Presentation/Themes/Navigation.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
