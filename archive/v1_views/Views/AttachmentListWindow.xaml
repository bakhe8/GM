<Window x:Class="GuaranteeManager.Views.AttachmentListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="المرفقات"
        Height="420"
        Width="560"
        WindowStartupLocation="CenterOwner"
        MinHeight="340"
        MinWidth="500"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource Surface_Bg_Light}"
        FontFamily="{StaticResource Font_Primary}"
        FlowDirection="RightToLeft">
    <Window.Resources>
        <Style x:Key="AttachmentList.Tile" TargetType="Border" BasedOn="{StaticResource Tile.Neutral}"/>
        <Style x:Key="AttachmentList.DangerButton" TargetType="Button" BasedOn="{StaticResource Button.CompactSubtle}">
            <Setter Property="Foreground" Value="{StaticResource Status_Error}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Status_Error}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Panel.Advisor}" Padding="12" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource Badge.Icon.Neutral}">
                    <Path Data="{StaticResource Icon_Geometry_Attachment}" Style="{StaticResource Path_SectionIcon}"/>
                </Border>
                <StackPanel>
                    <TextBlock Name="TxtHeader" Text="قائمة المرفقات" Style="{StaticResource Text_H1}" Margin="0"/>
                    <TextBlock Text="يمكن فتح الملفات الحالية أو حذفها عند السماح بذلك، مع إظهار حالة واضحة عند عدم وجود مرفقات."
                               Style="{StaticResource Text_Muted}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card.Panel}" Padding="4">
            <Grid>
                <ListBox Name="ListAttachments" Style="{StaticResource ListBox.Flat}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource AttachmentList.Tile}" Margin="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding OriginalFileName}" FontWeight="SemiBold" Foreground="{StaticResource Brand_Slate}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding UploadedAt, StringFormat=تاريخ الإضافة: yyyy-MM-dd HH:mm}" Margin="0,4,0,0" Style="{StaticResource Text_Caption}" Foreground="{StaticResource Brand_Slate}" Opacity="0.65"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Click="Open_Click" Margin="8,0,0,0" Style="{StaticResource Button.CompactSubtle}" ToolTip="فتح الملف خارج البرنامج" Tag="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource Icon_Geometry_Open}" Style="{StaticResource Path_ButtonIcon}"/>
                                                <TextBlock Text="فتح الملف" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Click="Delete_Click" Style="{StaticResource AttachmentList.DangerButton}" Tag="{Binding}" Visibility="{Binding DeleteButtonVisibility, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource Icon_Geometry_Delete}" Style="{StaticResource Path_ButtonIcon}"/>
                                                <TextBlock Text="حذف" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel x:Name="EmptyStatePanel"
                            Style="{StaticResource Panel.EmptyState}"
                            Visibility="Collapsed">
                    <Path Data="{StaticResource Icon_Geometry_Attachment}"/>
                    <TextBlock Text="لا توجد مرفقات متاحة لهذا السياق حاليًا."/>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="LocalStatusBorder" Grid.Row="2" Visibility="Collapsed" Margin="0,8,0,0" Style="{StaticResource Panel.Feedback}">
            <StackPanel>
                <TextBlock Text="آخر نتيجة" Style="{StaticResource Tile.Label}"/>
                <TextBlock x:Name="TxtLocalStatus" Style="{StaticResource Tile.Value}"/>
            </StackPanel>
        </Border>

        <Button x:Name="BtnClose" Grid.Row="3" Click="Close_Click" HorizontalAlignment="Left" Margin="0,8,0,0" IsCancel="True" Style="{StaticResource Button.Subtle}"/>
    </Grid>
</Window>
