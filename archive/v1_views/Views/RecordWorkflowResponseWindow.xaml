<Window x:Class="GuaranteeManager.Views.RecordWorkflowResponseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تسجيل رد البنك"
        Height="560"
        Width="760"
        MinHeight="520"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Surface_Bg_Light}"
        FlowDirection="RightToLeft"
        FontFamily="{StaticResource Font_Primary}">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Panel.Advisor}"
                Padding="12"
                Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource Badge.Icon.Emphasis}">
                    <Path Data="{StaticResource Icon_Geometry_Bank}" Style="{StaticResource Path_SectionIcon}"/>
                </Border>
                <StackPanel>
                    <TextBlock Text="تسجيل رد البنك" Style="{StaticResource Text_H1}" Margin="0"/>
                    <TextBlock Text="عند التأكيد تغلق هذه النافذة أولًا، ثم يسجل البرنامج الرد ويطبق أثره حسب النتيجة المختارة."
                               Style="{StaticResource Text_Muted}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card.Panel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" x:Name="LblGuaranteeNoHeader" Text="رقم الضمان" Style="{StaticResource InputLabel}"/>
                <TextBlock x:Name="TxtGuaranteeNo" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="2" x:Name="LblRequestTypeHeader" Text="نوع الطلب" Style="{StaticResource InputLabel}"/>
                <TextBlock x:Name="TxtRequestType" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" x:Name="LblCurrentValue" Text="القيمة الحالية" Style="{StaticResource InputLabel}" Margin="0,8,0,8"/>
                <TextBlock x:Name="TxtCurrentExpiry" Grid.Row="1" Grid.Column="1" Margin="0,8,0,8" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="2" x:Name="LblRequestedValue" Text="المطلوب" Style="{StaticResource InputLabel}" Margin="0,8,0,8"/>
                <TextBlock x:Name="TxtRequestedExpiry" Grid.Row="1" Grid.Column="3" Margin="0,8,0,8" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="استجابة البنك" Style="{StaticResource InputLabel}" Margin="0,8,0,8"/>
                <ComboBox x:Name="CmbResult" Grid.Row="2" Grid.Column="1" Margin="0,8,0,8" SelectionChanged="Result_SelectionChanged">
                    <ComboBoxItem Tag="Executed" Content="تم التنفيذ" IsSelected="True"/>
                    <ComboBoxItem Tag="Rejected" Content="مرفوض"/>
                    <ComboBoxItem Tag="Cancelled" Content="مُلغى"/>
                </ComboBox>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="مستند رد البنك (اختياري)" Style="{StaticResource InputLabel}" Margin="0,8,0,8"/>
                <Grid Grid.Row="2" Grid.Column="3" Margin="0,8,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtResponseFile" IsReadOnly="True"/>
                    <Button x:Name="BtnBrowseResponseFile" Grid.Column="1" Click="BrowseFile_Click" Style="{StaticResource Button.Subtle}" Margin="8,0,0,0"/>
                </Grid>

                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" x:Name="TxtResultGuidance" Style="{StaticResource Text_Muted}" Margin="0,0,0,8" TextWrapping="Wrap"/>

                <CheckBox x:Name="ChkPromoteResponseDocument"
                          Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4"
                          Content="اعتماد مستند رد البنك كمرفق رسمي وإنشاء إصدار جديد"
                          Visibility="Collapsed"
                          Margin="0,4,0,0"/>

                <TextBlock x:Name="TxtPromoteGuidance"
                           Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4"
                           Visibility="Collapsed"
                           Margin="0,4,0,8"
                           Style="{StaticResource Text_Muted}"
                           TextWrapping="Wrap"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="ملاحظات الرد" Style="{StaticResource InputLabel}" Margin="0,8,0,0"/>
                <TextBox x:Name="TxtResponseNotes"
                          Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3"
                          Margin="0,8,0,0"
                          AcceptsReturn="True"
                          TextWrapping="Wrap"
                          VerticalScrollBarVisibility="Auto"
                          MinHeight="100"
                          Padding="8"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    FlowDirection="LeftToRight"
                    Margin="0,8,0,0">
            <Button x:Name="BtnSave" Click="Save_Click" Style="{StaticResource Button.Primary}"/>
            <Button x:Name="BtnCancel" Click="Cancel_Click" Margin="8,0,0,0" ToolTip="يغلق هذه النافذة ويترك ما أدخلته دون حفظ." Style="{StaticResource Button.Subtle}"/>
        </StackPanel>
    </Grid>
</Window>
