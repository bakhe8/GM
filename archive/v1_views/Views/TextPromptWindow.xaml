<Window x:Class="GuaranteeManager.Views.TextPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إدخال قيمة"
        Height="280"
        Width="520"
        MinHeight="240"
        MinWidth="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Surface_Bg_Light}"
        FlowDirection="RightToLeft"
        FontFamily="{StaticResource Font_Primary}">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Panel.Advisor}"
                Padding="12"
                Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource Badge.Icon.Emphasis}">
                    <Path Data="{StaticResource Icon_Geometry_Confirm}" Style="{StaticResource Path_SectionIcon}"/>
                </Border>
                <StackPanel>
                    <TextBlock x:Name="TxtTitle" Text="إدخال قيمة" Style="{StaticResource Text_H1}" Margin="0"/>
                    <TextBlock x:Name="TxtPrompt" Text="أدخل القيمة المطلوبة." Style="{StaticResource Text_Muted}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    <Border x:Name="ActionHintBorder"
                            Style="{StaticResource Tile.Neutral}"
                            Margin="0,8,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TxtActionHint" Text="بعد اعتماد الإدخال، ينتقل البرنامج إلى الخطوة التالية." Style="{StaticResource Text_Caption}" Foreground="{StaticResource Brand_Slate}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card.Panel}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="TxtLabel" Text="القيمة" Style="{StaticResource InputLabel}" Margin="0,0,0,8"/>
                <TextBox x:Name="TxtValue"
                         Grid.Row="1"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    FlowDirection="LeftToRight"
                    Margin="0,8,0,0">
            <Button x:Name="BtnConfirm"
                    Content="اعتماد الإدخال والمتابعة"
                    ToolTip="يعتمد القيمة المدخلة ويغلق هذه النافذة للانتقال إلى الخطوة التالية."
                    Click="Confirm_Click"
                    Style="{StaticResource Button.Primary}"/>
            <Button x:Name="BtnCancel"
                    Content="إغلاق دون متابعة"
                    ToolTip="يغلق هذه النافذة ويترك الإدخال دون اعتماد."
                    Click="Cancel_Click"
                    Margin="8,0,0,0"
                    Style="{StaticResource Button.Subtle}"/>
        </StackPanel>
    </Grid>
</Window>
