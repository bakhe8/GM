<UserControl x:Class="GuaranteeManager.Views.GuaranteeFileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsVisibleChanged="View_IsVisibleChanged">
    <UserControl.Resources>
        <Style x:Key="GuaranteeFile.SummaryTile" TargetType="Border" BasedOn="{StaticResource Tile.Neutral}">
            <Setter Property="MinHeight" Value="90"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        <Style x:Key="GuaranteeFile.SummaryValue" TargetType="TextBlock" BasedOn="{StaticResource Text_Section}">
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="GuaranteeFile.ActionTile" TargetType="Border" BasedOn="{StaticResource Tile.Neutral}">
            <Setter Property="Width" Value="220"/>
            <Setter Property="MinHeight" Value="156"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>
        <Style x:Key="GuaranteeFile.SidebarTile" TargetType="Border" BasedOn="{StaticResource Tile.Neutral}">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="{StaticResource Neutral_025}"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Main Content Area -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Unified Header Section -->
            <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource Panel.Advisor}" Margin="{DynamicResource Space_Section_Bottom}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource Badge.Icon.Emphasis}">
                            <Path Data="{StaticResource Icon_Geometry_Advisor}" Style="{StaticResource Path_SectionIcon}"/>
                        </Border>
                        <StackPanel>
                            <TextBlock x:Name="TxtGuaranteeTitle" Style="{StaticResource Text_H2}" Text="ملف الضمان"/>
                            <TextBlock x:Name="TxtGuaranteeSubtitle" Margin="0,4,0,0" Style="{StaticResource Text_Muted}" Text="الملخص التنفيذي والتسلسل الزمني الكامل."/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource Button.Subtle}" Click="BackToPortfolio_Click" Content="العودة للمحفظة"/>
                    <Button Grid.Column="2" Margin="8,0,0,0" Style="{StaticResource Button.Subtle}" Click="Refresh_Click" Content="تحديث"/>
                    <Button Grid.Column="3" Margin="8,0,0,0" Style="{StaticResource Button.Primary}" Click="ExportSingle_Click" Content="تصدير الملف"/>
                </Grid>
            </Border>

            <!-- Left Side: Main Content -->
            <ScrollViewer Grid.Column="0"
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <StackPanel Margin="0,0,0,8">
                    <Grid x:Name="ExecutiveSummaryAnchor" Margin="{DynamicResource Space_Section_Bottom}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" Style="{StaticResource GuaranteeFile.SummaryTile}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text_Caption}" Text="القيمة الحالية"/>
                            <TextBlock x:Name="TxtGuaranteeAmount" Style="{StaticResource GuaranteeFile.SummaryValue}" Text="0.00"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" Margin="0,0,8,8" Style="{StaticResource GuaranteeFile.SummaryTile}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text_Caption}" Text="الانتهاء الحالي"/>
                            <TextBlock x:Name="TxtGuaranteeExpiry" Style="{StaticResource GuaranteeFile.SummaryValue}" Text="--"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="2" Margin="0,0,0,8" Style="{StaticResource GuaranteeFile.SummaryTile}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text_Caption}" Text="عدد الإصدارات"/>
                            <TextBlock x:Name="TxtGuaranteeVersionCount" Style="{StaticResource GuaranteeFile.SummaryValue}" Text="0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" Style="{StaticResource GuaranteeFile.SummaryTile}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text_Caption}" Text="نوع الضمان"/>
                            <TextBlock x:Name="TxtCurrentType" Style="{StaticResource GuaranteeFile.SummaryValue}" Text="--"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Margin="0,0,8,0" Style="{StaticResource GuaranteeFile.SummaryTile}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text_Caption}" Text="الحالة الزمنية"/>
                            <TextBlock x:Name="TxtCurrentStatus" Style="{StaticResource GuaranteeFile.SummaryValue}" Text="--"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="2" Margin="0,0,0,0" Style="{StaticResource GuaranteeFile.SummaryTile}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text_Caption}" Text="الحالة التشغيلية"/>
                            <TextBlock x:Name="TxtLifecycleStatus" Style="{StaticResource GuaranteeFile.SummaryValue}" Text="--"/>
                        </StackPanel>
                    </Border>
                    </Grid>

                    <StackPanel>
                        <Border x:Name="InquiryAnchor"
                                Margin="{DynamicResource Space_Section_Bottom}"
                                Style="{StaticResource Card.Panel}"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Text_Section}" Text="افهم هذا الضمان"/>
                                <TextBlock x:Name="TxtInquiryHint" Margin="0,8,0,0" Style="{StaticResource Text_Body}"/>
                                <StackPanel x:Name="InquiryActionPanel" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="CommandHubAnchor"
                                Margin="{DynamicResource Space_Section_Bottom}"
                                Style="{StaticResource Card.Panel}"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Style="{StaticResource Text_Section}" Text="الإجراءات السريعة"/>
                                <TextBlock Margin="0,4,0,0"
                                           Style="{StaticResource Text_Muted}"
                                           Text="تتجمع هنا كل الإجراءات التي يتيحها هذا الضمان الآن بدل توزيعها على بطاقات منفصلة طويلة."/>
                                <WrapPanel Margin="0,12,0,0" FlowDirection="RightToLeft">
                                    <Border x:Name="EditAnchor"
                                            Style="{StaticResource GuaranteeFile.ActionTile}"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Text_Section}" Text="تعديل الضمان"/>
                                            <TextBlock x:Name="TxtEditHint" Margin="0,8,0,0" Style="{StaticResource Text_Body}" TextWrapping="Wrap"/>
                                            <Button x:Name="BtnEditGuarantee" Margin="0,12,0,0" Style="{StaticResource Button.Subtle}" Click="EditGuarantee_Click" Content="فتح شاشة التعديل"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="ExtensionAnchor"
                                            Style="{StaticResource GuaranteeFile.ActionTile}"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Text_Section}" Text="طلب تمديد"/>
                                            <TextBlock x:Name="TxtExtensionHint" Margin="0,8,0,0" Style="{StaticResource Text_Body}" TextWrapping="Wrap"/>
                                            <Button x:Name="BtnRequestExtension" Margin="0,12,0,0" Style="{StaticResource Button.Subtle}" Click="RequestExtension_Click" Content="بدء طلب تمديد"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="ReductionAnchor"
                                            Style="{StaticResource GuaranteeFile.ActionTile}"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Text_Section}" Text="طلب تخفيض"/>
                                            <TextBlock x:Name="TxtReductionHint" Margin="0,8,0,0" Style="{StaticResource Text_Body}" TextWrapping="Wrap"/>
                                            <Button x:Name="BtnRequestReduction" Margin="0,12,0,0" Style="{StaticResource Button.Subtle}" Click="RequestReduction_Click" Content="تقديم طلب تخفيض"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="ReleaseAnchor"
                                            Style="{StaticResource GuaranteeFile.ActionTile}"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Text_Section}" Text="طلب إفراج"/>
                                            <TextBlock x:Name="TxtReleaseHint" Margin="0,8,0,0" Style="{StaticResource Text_Body}" TextWrapping="Wrap"/>
                                            <Button x:Name="BtnRequestRelease" Margin="0,12,0,0" Style="{StaticResource Button.Subtle}" Click="RequestRelease_Click" Content="تقديم طلب إفراج"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="LiquidationAnchor"
                                            Style="{StaticResource GuaranteeFile.ActionTile}"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Text_Section}" Text="طلب تسييل"/>
                                            <TextBlock x:Name="TxtLiquidationHint" Margin="0,8,0,0" Style="{StaticResource Text_Body}" TextWrapping="Wrap"/>
                                            <Button x:Name="BtnRequestLiquidation" Margin="0,12,0,0" Style="{StaticResource Button.Subtle}" Click="RequestLiquidation_Click" Content="تقديم طلب تسييل"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="VerificationAnchor"
                                            Style="{StaticResource GuaranteeFile.ActionTile}"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Text_Section}" Text="طلب تحقق"/>
                                            <TextBlock x:Name="TxtVerificationHint" Margin="0,8,0,0" Style="{StaticResource Text_Body}" TextWrapping="Wrap"/>
                                            <Button x:Name="BtnRequestVerification" Margin="0,12,0,0" Style="{StaticResource Button.Subtle}" Click="RequestVerification_Click" Content="تقديم طلب تحقق"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="ReplacementAnchor"
                                            Style="{StaticResource GuaranteeFile.ActionTile}"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Text_Section}" Text="طلب استبدال"/>
                                            <TextBlock x:Name="TxtReplacementHint" Margin="0,8,0,0" Style="{StaticResource Text_Body}" TextWrapping="Wrap"/>
                                            <Button x:Name="BtnRequestReplacement" Margin="0,12,0,0" Style="{StaticResource Button.Subtle}" Click="RequestReplacement_Click" Content="تقديم طلب استبدال"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="AnnulmentAnchor"
                                            Style="{StaticResource GuaranteeFile.ActionTile}"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource Text_Section}" Text="نقض الإجراء"/>
                                            <TextBlock x:Name="TxtAnnulmentHint" Margin="0,8,0,0" Style="{StaticResource Text_Body}" TextWrapping="Wrap"/>
                                            <Button Margin="0,12,0,0" Style="{StaticResource Button.Subtle}" Click="RequestAnnulment_Click" Content="تقديم طلب نقض"/>
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border x:Name="ActionsAnchor"
                            Style="{StaticResource Card.Panel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource Text_Section}" Text="الطلبات المرتبطة"/>
                                <TextBlock Style="{StaticResource Text_Muted}" Margin="0,4,0,0" Text="تظهر هنا جميع الطلبات المرتبطة بنفس سلسلة الضمان الحالية."/>
                            </StackPanel>
                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <DataGrid x:Name="GridRelatedRequests"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          MinHeight="180"
                                          Visibility="Collapsed"
                                          SelectionChanged="GridRelatedRequests_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Request.SequenceNumber}" Width="0.5*" MinWidth="40" ElementStyle="{StaticResource DataGridText.Center}"/>
                                        <DataGridTextColumn Header="النوع" Binding="{Binding Request.TypeLabel}" Width="1.2*" MinWidth="110" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                                        <DataGridTextColumn Header="الحالة" Binding="{Binding Request.StatusLabel}" Width="1*" MinWidth="90" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                                        <DataGridTextColumn Header="المطلوب" Binding="{Binding RequestedValueDisplay}" Width="1.3*" MinWidth="120" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                                        <DataGridTextColumn Header="التاريخ" Binding="{Binding RequestDateLabel}" Width="1*" MinWidth="100" ElementStyle="{StaticResource DataGridText.Center}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel x:Name="RequestEmptyStatePanel"
                                            Grid.Row="0"
                                            Style="{StaticResource Panel.EmptyState}"
                                            Visibility="Collapsed">
                                    <Path Data="{StaticResource Icon_Geometry_Advisor}"/>
                                    <TextBlock Text="لا توجد طلبات مرتبطة بهذه السلسلة حتى الآن."/>
                                    <TextBlock Margin="0,8,0,0" Text="عند إنشاء أي طلب من هذا الملف سيظهر هنا مع خطاب الطلب ورد البنك."/>
                                </StackPanel>
                                <Grid x:Name="RequestActionBar" Grid.Row="1" Margin="0,8,0,0" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="TxtRequestSelectionHint"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource Text_Muted}"
                                               Text="حدد طلبًا لفتح خطاب الطلب أو مستند الرد."/>
                                    <Button Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource Button.Primary}" Click="OpenOperations_Click" Content="فتح شاشة الطلبات"/>
                                    <Button Grid.Column="2" Margin="8,0,0,0" Style="{StaticResource Button.Subtle}" x:Name="BtnOpenRequestLetter" Click="OpenSelectedRequestLetter_Click" Content="خطاب الطلب"/>
                                    <Button Grid.Column="3" Margin="8,0,0,0" Style="{StaticResource Button.Subtle}" x:Name="BtnOpenRequestResponse" Click="OpenSelectedRequestResponse_Click" Content="مستند الرد"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Right Side: Sidebar -->
            <Grid Grid.Column="1" Grid.Row="1" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <Border x:Name="TimelineAnchor"
                        Grid.Row="0"
                        Style="{StaticResource Card.Panel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text_Section}" Text="السجل الزمني"/>
                            <TextBlock Style="{StaticResource Text_Muted}" Margin="0,4,0,0" Text="هنا تتجمع الإصدارات والطلبات وأي مستندات مرافقة في سرد تشغيلي واحد."/>
                        </StackPanel>
                        <StackPanel x:Name="TimelineEmptyStatePanel"
                                    Grid.Row="1"
                                    Margin="0,12,0,0"
                                    Style="{StaticResource Panel.EmptyState}"
                                    Visibility="Collapsed">
                            <Path Data="{StaticResource Icon_Geometry_History}"/>
                            <TextBlock Text="لا توجد عناصر زمنية لعرضها لهذا الضمان حاليًا."/>
                        </StackPanel>
                        <ScrollViewer x:Name="TimelineScrollHost"
                                      Grid.Row="1"
                                      Margin="0,12,0,0"
                                      VerticalScrollBarVisibility="Auto"
                                      Visibility="Collapsed">
                            <ItemsControl x:Name="TimelineItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource GuaranteeFile.SidebarTile}">
                                            <StackPanel>
                                                <TextBlock FontWeight="Bold" Text="{Binding Title}"/>
                                                <TextBlock Margin="0,4,0,0" Style="{StaticResource Text_Body}" Text="{Binding Description}"/>
                                                <TextBlock Margin="0,6,0,0" Style="{StaticResource Text_Caption}" Text="{Binding Stamp}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border x:Name="AttachmentsAnchor" Grid.Row="1" Margin="0,8,0,0" Style="{StaticResource Card.Panel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text_Section}" Text="مرفقات الإصدار الحالي"/>
                            <TextBlock x:Name="TxtAttachmentCount" Margin="0,4,0,0" Style="{StaticResource Text_Muted}" Text="0 مرفق"/>
                        </StackPanel>
                        <StackPanel x:Name="AttachmentEmptyStatePanel"
                                    Grid.Row="2"
                                    Margin="0,12,0,0"
                                    Style="{StaticResource Panel.EmptyState}"
                                    Visibility="Collapsed">
                            <Path Data="{StaticResource Icon_Geometry_Attachment}"/>
                            <TextBlock Text="لا توجد مرفقات حالية لهذا الإصدار."/>
                        </StackPanel>
                        <ScrollViewer x:Name="AttachmentScrollHost"
                                      Grid.Row="2"
                                      Margin="0,12,0,0"
                                      Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="AttachmentItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource GuaranteeFile.SidebarTile}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding OriginalFileName}"/>
                                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource Text_Caption}" Text="{Binding UploadedAtLabel}"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource Button.Subtle}" Tag="{Binding FilePath}" Click="AttachmentOpen_Click" Content="فتح"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
