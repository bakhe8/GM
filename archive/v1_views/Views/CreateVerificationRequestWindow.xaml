<Window x:Class="GuaranteeManager.Views.CreateVerificationRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="طلب تأكيد صحة صدور جديد"
        Height="500"
        Width="760"
        MinHeight="460"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Surface_Bg_Light}"
        FlowDirection="RightToLeft"
        FontFamily="{StaticResource Font_Primary}">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Panel.Advisor}" Margin="0,0,0,8" Padding="12">
            <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource Badge.Icon.Emphasis}">
                    <Path Data="{StaticResource Icon_Geometry_Advisor}" Style="{StaticResource Path_SectionIcon}"/>
                </Border>
                <StackPanel>
                    <TextBlock Text="طلب تأكيد صحة صدور جديد" Style="{StaticResource Text_H1}" Margin="0"/>
                    <TextBlock Text="يسجل الطلب كمعلق لمتابعة وصول تأكيد صحة صدور الضمان من البنك. لا يغيّر هذا المسار المبلغ أو الانتهاء، لكنه يضيف متابعة رسمية على الضمان المحدد."
                               Style="{StaticResource Text_Muted}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                    <Border Style="{StaticResource Tile.Neutral}" Margin="0,8,0,0">
                        <TextBlock Text="اختر الضمان الصحيح وأدخل اسم منشئ الطلب ثم أضف أي ملاحظات مساندة قبل إنشاء المتابعة."
                                   Style="{StaticResource Text_Caption}"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Form Card -->
        <Border Grid.Row="1" Style="{StaticResource Card.Panel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="الضمان" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                <ComboBox x:Name="CmbGuarantee"
                          Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                          DisplayMemberPath="WorkflowDisplayLabel"
                          SelectionChanged="Guarantee_SelectionChanged"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="المورد" Style="{StaticResource InputLabel}" Margin="0,8,0,8"/>
                <TextBlock x:Name="TxtSupplier" Grid.Row="1" Grid.Column="1" Margin="0,8,0,8" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="البنك" Style="{StaticResource InputLabel}" Margin="0,8,0,8"/>
                <TextBlock x:Name="TxtBank" Grid.Row="1" Grid.Column="3" Margin="0,8,0,8" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="منشئ الطلب" Style="{StaticResource InputLabel}" Margin="0,8,0,8"/>
                <TextBox x:Name="TxtCreatedBy" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,8,0,8"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="ملاحظات الطلب" Style="{StaticResource InputLabel}" Margin="0,8,0,8"/>
                <TextBox x:Name="TxtNotes"
                          Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4"
                          Margin="0,8,0,0"
                          AcceptsReturn="True"
                          TextWrapping="Wrap"
                          VerticalScrollBarVisibility="Auto"
                          MinHeight="140"
                          Padding="8"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,8,0,0">
            <Border Style="{StaticResource Tile.Neutral}">
                <TextBlock x:Name="TxtSaveGuidance"
                           Style="{StaticResource Text_Caption}"
                           Text="اختر الضمان المطلوب وأدخل اسم منشئ الطلب قبل الحفظ."/>
            </Border>
            <StackPanel Orientation="Horizontal" FlowDirection="LeftToRight">
                <Button x:Name="BtnSave"
                        Content="متابعة إنشاء الطلب"
                        Click="Save_Click"
                        Style="{StaticResource Button.Primary}"/>
                <Button Content="إغلاق دون حفظ"
                        Click="Cancel_Click"
                        Margin="8,0,0,0"
                        Style="{StaticResource Button.Subtle}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
