<UserControl x:Class="GuaranteeManager.Views.CreateExtensionRequestSideSheetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="{DynamicResource Space_Padding_SideSheet}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource Surface_Active}"
                BorderBrush="{StaticResource Surface_Border}"
                BorderThickness="1"
                CornerRadius="{StaticResource Corner_Inner}"
                Padding="12">
            <StackPanel>
                <TextBlock Style="{StaticResource Text_Caption}" Text="سياق الضمان"/>
                <TextBlock x:Name="TxtGuaranteeIdentity"
                           Margin="0,6,0,0"
                           Style="{StaticResource Text_Section}"
                           Text="BG-0000 | المورد"/>
                <TextBlock x:Name="TxtGuaranteeSummary"
                           Margin="0,4,0,0"
                           Style="{StaticResource Text_Muted}"
                           Text="القيمة والانتهاء والحالة"/>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource Card.Compact}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text_Caption}" Text="القيمة الحالية"/>
                            <TextBlock x:Name="TxtCurrentAmount"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource Text_Section}"
                                       Text="0.00"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource Card.Compact}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text_Caption}" Text="الانتهاء الحالي"/>
                            <TextBlock x:Name="TxtCurrentExpiry"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource Text_Section}"
                                       Text="--"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="{DynamicResource Space_Section_Top}"
                Style="{StaticResource Card.Panel}">
            <StackPanel>
                <TextBlock Style="{StaticResource Text_Section}" Text="بدء طلب تمديد"/>
                <TextBlock x:Name="TxtReasonSummary"
                           Margin="0,6,0,0"
                           Style="{StaticResource Text_Body}"
                           TextWrapping="Wrap"
                           Text="هذا الضمان يقترب من الانتهاء ولا يوجد له طلب تمديد مفتوح الآن."/>

                <Border x:Name="PendingRequestPanel"
                        Margin="0,12,0,0"
                        Background="{StaticResource Surface_Active}"
                        BorderBrush="{StaticResource Status_Warning}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Corner_Inner}"
                        Padding="12"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text_Section}" Text="يوجد طلب تمديد مفتوح"/>
                        <TextBlock x:Name="TxtPendingRequestSummary"
                                   Margin="0,6,0,0"
                                   Style="{StaticResource Text_Body}"
                                   TextWrapping="Wrap"
                                   Text="يوجد طلب تمديد معلق لهذا الضمان."/>
                        <Button x:Name="BtnOpenExistingRequest"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Left"
                                Style="{StaticResource Button.Subtle}"
                                Click="OpenExistingRequest_Click"
                                Content="عرض الطلب القائم"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Style="{StaticResource InputLabel}"
                               Text="نوع الإجراء"/>
                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Margin="0,4,0,4"
                               VerticalAlignment="Center"
                               Style="{StaticResource Text_Section}"
                               Text="طلب تمديد"/>

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Style="{StaticResource InputLabel}"
                               Text="التاريخ المطلوب"/>
                    <DatePicker x:Name="DateRequestedExpiry"
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,4,0,4"
                                SelectedDateChanged="RequestedExpiry_Changed"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               Style="{StaticResource InputLabel}"
                               Text="منشئ الطلب"/>
                    <TextBox x:Name="TxtCreatedBy"
                             Grid.Row="2"
                             Grid.Column="1"
                             Margin="0,4,0,4"
                             TextChanged="CreatedBy_Changed"/>

                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               VerticalAlignment="Top"
                               Style="{StaticResource InputLabel}"
                               Text="ملاحظات الطلب"/>
                    <TextBox x:Name="TxtNotes"
                             Grid.Row="3"
                             Grid.Column="1"
                             Margin="0,4,0,0"
                             MinHeight="110"
                             Padding="8"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </Grid>

                <Border Margin="0,16,0,0"
                        Style="{StaticResource Tile.Neutral}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text_Caption}" Text="معاينة الأثر قبل الحفظ"/>
                        <TextBlock x:Name="TxtEffectPreview"
                                   Margin="0,6,0,0"
                                   Style="{StaticResource Text_Body}"
                                   TextWrapping="Wrap"
                                   Text="بعد الحفظ سيُنشأ طلب تمديد معلق ويظهر في هذا الملف مباشرة."/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="TxtSaveGuidance"
                           Margin="0,12,0,0"
                           Style="{StaticResource Text_Caption}"
                           Text="أكمل التاريخ المطلوب واسم منشئ الطلب قبل الحفظ."/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2"
              Margin="{DynamicResource Space_Section_Top}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BtnSave"
                    Grid.Column="2"
                    Style="{StaticResource Button.Primary}"
                    Click="Save_Click"
                    Content="إنشاء طلب التمديد"/>
            <Button Grid.Column="4"
                    Style="{StaticResource Button.Subtle}"
                    Click="Cancel_Click"
                    Content="إغلاق"/>
        </Grid>
    </Grid>
</UserControl>
