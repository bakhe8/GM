<UserControl x:Class="GuaranteeManager.Views.DataTableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource MetricStrip.Panel}"
                CornerRadius="{StaticResource Corner_Inner}">
            <Grid Height="80">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Style="{StaticResource MetricStrip.ItemStack}">
                    <TextBlock Style="{StaticResource Text_Caption}" Text="إجمالي المحفظة"/>
                    <TextBlock Style="{StaticResource Text_Metric}" Text="{Binding GuaranteeCount}" Margin="0,4,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Style="{StaticResource MetricStrip.Separator}"/>

                <StackPanel Grid.Column="2" Style="{StaticResource MetricStrip.ItemStack}">
                    <TextBlock Style="{StaticResource Text_Caption}" Text="نشطة الآن"/>
                    <TextBlock Style="{StaticResource Text_Metric}" Text="{Binding ActiveCount}" Margin="0,4,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="3" Style="{StaticResource MetricStrip.Separator}"/>

                <StackPanel Grid.Column="4" Style="{StaticResource MetricStrip.ItemStack}">
                    <TextBlock Style="{StaticResource Text_Caption}" Text="طلبات معلقة"/>
                    <TextBlock Style="{StaticResource Text_Metric}" Text="{Binding PendingRequestCount}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="{DynamicResource Space_Section_Bottom}"
                Style="{StaticResource Card.Panel}"
                CornerRadius="{StaticResource Corner_Inner}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text_Section}" Text="محفظة الضمانات"/>
                        <TextBlock
                                   Margin="0,4,0,0"
                                   Style="{StaticResource Text_Muted}"
                                   Text="{Binding PortfolioSummary}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource Button.Primary}" Click="OpenSelected_Click" Content="فتح الملف" IsEnabled="{Binding HasFilteredGuarantees}"/>
                    <Button Grid.Column="2" Margin="8,0,0,0" Style="{StaticResource Button.Subtle}" Click="ExportFiltered_Click" Content="تصدير المعروض"/>
                    <Button Grid.Column="3" Margin="8,0,0,0" Style="{StaticResource Button.Subtle}" Click="Refresh_Click" Content="تحديث"/>
                </Grid>

                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtSearchLocal" Text="{Binding SearchText, Mode=OneWay}" TextChanged="FiltersChanged" ToolTip="بحث برقم الضمان أو المورد أو البنك"/>
                    <ComboBox x:Name="CmbBankFilter" Grid.Column="1" Margin="8,0,0,0" ItemsSource="{Binding BankOptions}" SelectedItem="{Binding SelectedBank, Mode=OneWay}" SelectionChanged="FiltersChanged"/>
                    <ComboBox x:Name="CmbTypeFilter" Grid.Column="2" Margin="8,0,0,0" ItemsSource="{Binding TypeOptions}" SelectedItem="{Binding SelectedType, Mode=OneWay}" SelectionChanged="FiltersChanged"/>
                    <ComboBox x:Name="CmbStatusFilter" Grid.Column="3" Margin="8,0,0,0" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus, Mode=OneWay}" SelectionChanged="FiltersChanged"/>
                    <Button Grid.Column="4" Margin="8,0,0,0" Style="{StaticResource Button.Subtle}" Click="ClearFilters_Click" Content="إعادة ضبط"/>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource Card.Panel}"
                CornerRadius="{StaticResource Corner_Inner}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource Text_Section}" Text="السجلات المعروضة"/>
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource Text_Muted}"
                               Text="يعرض الجدول الضمانات المطابقة للبحث والمرشحات الحالية، ويمكن فتح السجل أو استخدام الإجراءات السياقية من نفس القائمة."/>
                </StackPanel>

                <DataGrid x:Name="GridGuarantees"
                          Grid.Row="1"
                          Margin="{DynamicResource Space_Section_Top}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding FilteredGuarantees}"
                          SelectedItem="{Binding SelectedGuarantee, Mode=TwoWay}"
                          PreviewMouseLeftButtonDown="GridGuarantees_PreviewMouseLeftButtonDown"
                          SelectionChanged="GridGuarantees_SelectionChanged"
                          PreviewMouseRightButtonDown="GridGuarantees_PreviewMouseRightButtonDown"
                          ContextMenuOpening="GridGuarantees_ContextMenuOpening"
                          MouseDoubleClick="GridGuarantees_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الضمان" Binding="{Binding GuaranteeNo}" Width="1.1*" MinWidth="100" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                        <DataGridTextColumn Header="المورد" Binding="{Binding Supplier}" Width="1.5*" MinWidth="150" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                        <DataGridTextColumn Header="البنك" Binding="{Binding Bank}" Width="1.2*" MinWidth="120" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                        <DataGridTextColumn Header="النوع" Binding="{Binding GuaranteeType}" Width="1.1*" MinWidth="100" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                        <DataGridTextColumn Header="القيمة" Binding="{Binding Amount, StringFormat=N2}" Width="1*" MinWidth="100" ElementStyle="{StaticResource DataGridText.Ltr}"/>
                        <DataGridTextColumn Header="الانتهاء" Binding="{Binding ExpiryDate, StringFormat=yyyy-MM-dd}" Width="1*" MinWidth="100" ElementStyle="{StaticResource DataGridText.Center}"/>
                        <DataGridTextColumn Header="الحالة" Binding="{Binding StatusLabel}" Width="0.9*" MinWidth="80" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                        <DataGridTextColumn Header="الإصدار" Binding="{Binding VersionLabel}" Width="0.7*" MinWidth="60" ElementStyle="{StaticResource DataGridText.Center}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
