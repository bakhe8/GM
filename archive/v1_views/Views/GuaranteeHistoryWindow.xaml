<Window x:Class="GuaranteeManager.Views.GuaranteeHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="سجل الضمان"
        Height="680"
        Width="1020"
        MinHeight="560"
        MinWidth="860"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Surface_Bg_Light}"
        FlowDirection="RightToLeft"
        FontFamily="{StaticResource Font_Primary}"
        IsVisibleChanged="View_IsVisibleChanged">
    <Window.Resources>
        <Style x:Key="History.SummaryTile" TargetType="Border" BasedOn="{StaticResource Tile.Neutral}">
            <Setter Property="MinHeight" Value="82"/>
        </Style>
        <Style x:Key="History.SummaryTile.Success" TargetType="Border" BasedOn="{StaticResource Tile.Success}">
            <Setter Property="MinHeight" Value="82"/>
        </Style>
        <Style x:Key="History.ActionTile" TargetType="Border" BasedOn="{StaticResource Tile.Neutral}">
            <Setter Property="MinHeight" Value="132"/>
        </Style>
        <Style x:Key="History.FeedbackPanel" TargetType="Border" BasedOn="{StaticResource Panel.Feedback}"/>
        <Style x:Key="History.TileLabel" TargetType="TextBlock" BasedOn="{StaticResource Tile.Label}"/>
        <Style x:Key="History.TileValue" TargetType="TextBlock" BasedOn="{StaticResource Tile.Value}"/>
        <Style x:Key="History.FeedbackLabel" TargetType="TextBlock" BasedOn="{StaticResource Tile.Label}"/>
        <Style x:Key="History.FeedbackValue" TargetType="TextBlock" BasedOn="{StaticResource Tile.Value}"/>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Panel.Advisor}" Padding="12" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <StackPanel HorizontalAlignment="Right">
                    <TextBlock Name="TxtGuaranteeNo"
                               Text="سجل الضمان"
                               Style="{StaticResource Text_H1}"
                               Margin="0"
                               TextAlignment="Right"/>
                    <TextBlock Name="TxtSupplierBank"
                               Margin="0,4,0,0"
                               Style="{StaticResource Text_Body}"
                               Foreground="{StaticResource Brand_Slate}"
                               TextAlignment="Right"
                               HorizontalAlignment="Right"/>
                    <TextBlock Name="TxtContext"
                               Margin="0,4,0,0"
                               Style="{StaticResource Text_Caption}"
                               Foreground="{StaticResource Brand_Slate}"
                               Opacity="0.7"
                               Text="يعرض جميع الإصدارات المرتبطة بنفس رقم الضمان."
                               TextAlignment="Right"
                               HorizontalAlignment="Right"/>
                </StackPanel>

                <Border Style="{StaticResource Badge.Icon.Emphasis}" Margin="8,0,0,0">
                    <Path Data="{StaticResource Icon_Geometry_History}" Style="{StaticResource Path_SectionIcon}"/>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource History.SummaryTile.Success}">
                    <StackPanel>
                        <TextBlock Text="الإصدار الحالي" Style="{StaticResource History.TileLabel}"/>
                        <TextBlock Name="TxtCurrentVersion" Margin="0,6,0,0" Style="{StaticResource Text_Section}" Foreground="{StaticResource Brand_Emerald}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource History.SummaryTile}">
                    <StackPanel>
                        <TextBlock Text="أول تسجيل" Style="{StaticResource History.TileLabel}"/>
                        <TextBlock Name="TxtFirstCreated" Margin="0,6,0,0" Style="{StaticResource History.TileValue}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource History.SummaryTile}">
                    <StackPanel>
                        <TextBlock Text="آخر تحديث" Style="{StaticResource History.TileLabel}"/>
                        <TextBlock Name="TxtLastUpdated" Margin="0,6,0,0" Style="{StaticResource History.TileValue}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource Card.Panel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="إصدارات الضمان" Style="{StaticResource Text_H2}" Margin="0"/>
                            <TextBlock Text="يعرض جميع الإصدارات المحفوظة بنفس رقم الضمان، مع تمييز الإصدار الحالي داخل الجدول."
                                       Margin="0,4,0,0"
                                       Style="{StaticResource Text_Muted}"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource Text_Caption}"
                                   Foreground="{StaticResource Brush_Text_Muted}"
                                   Text="حدد أي إصدار لمراجعة مرفقاته."/>
                    </Grid>

                    <DataGrid Name="GridHistory"
                              Grid.Row="1"
                              Margin="0,12,0,0"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              AlternationCount="2"
                              SelectionChanged="GridHistory_SelectionChanged">
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#E6E6E6"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E6E6E6"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#111111"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#111111"/>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="GridHistoryRow_PreviewMouseLeftButtonDown"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Surface_Active}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="الإصدار" Binding="{Binding VersionNumber, StringFormat=v{0}}" Width="0.8*" MinWidth="70" ElementStyle="{StaticResource DataGridText.Center}"/>
                            <DataGridTextColumn Header="الحالة" Binding="{Binding VersionStatusLabel}" Width="0.8*" MinWidth="80" ElementStyle="{StaticResource DataGridText.Center}"/>
                            <DataGridTextColumn Header="الملاحظات" Binding="{Binding Notes}" Width="2.5*" MinWidth="200" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                            <DataGridTextColumn Header="المرفقات" Binding="{Binding Attachments.Count}" Width="0.7*" MinWidth="60" ElementStyle="{StaticResource DataGridText.Center}"/>
                            <DataGridTextColumn Header="تاريخ الإنشاء" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="1.2*" MinWidth="130" ElementStyle="{StaticResource DataGridText.Center}"/>
                            <DataGridTextColumn Header="الانتهاء" Binding="{Binding ExpiryDate, StringFormat={}{0:yyyy-MM-dd}}" Width="1*" MinWidth="100" ElementStyle="{StaticResource DataGridText.Center}"/>
                            <DataGridTextColumn Header="المبلغ" Binding="{Binding Amount, StringFormat={}{0:N2}}" Width="1.2*" MinWidth="110" ElementStyle="{StaticResource DataGridText.Ltr}"/>
                            <DataGridTextColumn Header="النوع" Binding="{Binding GuaranteeType}" Width="1*" MinWidth="90" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource Card.Panel}" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock x:Name="TxtHistoryActionsTitle" Text="الإجراءات المتاحة" Style="{StaticResource Text_H2}" Margin="0"/>
                    <TextBlock x:Name="TxtHistoryActionsSummary" Text="اختر إصدارًا من الجدول لفتح مرفقاته أو لتصدير وطباعة سجل الضمان."
                               Style="{StaticResource Text_Muted}"
                               Margin="0,4,0,0"/>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource History.ActionTile}">
                            <StackPanel>
                                <TextBlock Text="مرفقات الإصدار" Style="{StaticResource Text_Section}"/>
                                <TextBlock x:Name="TxtAttachmentsActionHint"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource Text_Muted}"
                                           Text="افتح الملفات المرافقة للإصدار المحدد فقط."
                                           TextWrapping="Wrap"/>
                                <Button x:Name="BtnViewAttachments"
                                        Margin="0,12,0,0"
                                        Style="{StaticResource Button.Subtle}"
                                        Click="ViewSelectedVersionFiles_Click"
                                        Content="فتح مرفقات الإصدار"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource History.ActionTile}">
                            <StackPanel>
                                <TextBlock Text="تصدير Excel" Style="{StaticResource Text_Section}"/>
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource Text_Muted}"
                                           Text="استخرج سجل الضمان كاملًا إلى ملف Excel واحد يشمل جميع الإصدارات."
                                           TextWrapping="Wrap"/>
                                <Button x:Name="BtnExportHistory"
                                        Margin="0,12,0,0"
                                        Style="{StaticResource Button.Primary}"
                                        Click="ExportHistory_Click"
                                        Content="تصدير سجل الضمان"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Style="{StaticResource History.ActionTile}">
                            <StackPanel>
                                <TextBlock Text="طباعة السجل" Style="{StaticResource Text_Section}"/>
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource Text_Muted}"
                                           Text="أرسل سجل الضمان كاملًا للطباعة مع إبقاء الإصدار المحدد ظاهرًا ضمن السجل."
                                           TextWrapping="Wrap"/>
                                <Button x:Name="BtnPrintHistory"
                                        Margin="0,12,0,0"
                                        Style="{StaticResource Button.Subtle}"
                                        Click="Print_Click"
                                        Content="طباعة سجل الضمان"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="LocalStatusBorder" Grid.Row="3" Visibility="Collapsed" Margin="0,8,0,0" Style="{StaticResource History.FeedbackPanel}">
            <StackPanel>
                <TextBlock Text="آخر نتيجة" Style="{StaticResource History.FeedbackLabel}"/>
                <TextBlock x:Name="TxtLocalStatus" Style="{StaticResource History.FeedbackValue}"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight" Margin="0,8,0,0">
            <Button x:Name="BtnClose" Click="Close_Click" Style="{StaticResource Button.Subtle}"/>
        </StackPanel>
    </Grid>
</Window>
