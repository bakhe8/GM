<UserControl x:Class="GuaranteeManager.Views.AddEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:GuaranteeManager.Models"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="AddEntry.InnerCard"
               TargetType="Border"
               BasedOn="{StaticResource Card.Panel}">
            <Setter Property="CornerRadius" Value="{StaticResource Corner_Inner}"/>
            <Setter Property="Padding" Value="{StaticResource Padding_Card}"/>
        </Style>

        <Style x:Key="AddEntry.FieldHost" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="AddEntry.FieldHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E53E3E"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

        <Style x:Key="AddEntry.FieldLabel"
               TargetType="TextBlock"
               BasedOn="{StaticResource Text_Caption}">
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="AddEntry.ReportCard"
               TargetType="Border"
               BasedOn="{StaticResource Tile.Neutral}">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="MinHeight" Value="100"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Y"
                                                 To="-4" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Y"
                                                 To="0" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AddEntry.ReportTitle"
               TargetType="TextBlock"
               BasedOn="{StaticResource Text_Section}">
            <Setter Property="FlowDirection" Value="RightToLeft"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
            <Setter Property="LineHeight" Value="22"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="AddEntry.ReportSummary"
               TargetType="TextBlock"
               BasedOn="{StaticResource Text_Body}">
            <Setter Property="FlowDirection" Value="RightToLeft"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="Regular"/>
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
            <Setter Property="LineHeight" Value="22"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style x:Key="AddEntry.AttachmentItem"
               TargetType="ListBoxItem"
               BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource Corner_Inner}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Brand_Emerald}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Brand_Emerald_12}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Brand_Emerald}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddEntry.AttachmentList"
               TargetType="ListBox"
               BasedOn="{StaticResource ListBox.Flat}">
            <Style.Triggers>
                <Trigger Property="HasItems" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AddEntry.AttachmentEmptyState"
               TargetType="StackPanel"
               BasedOn="{StaticResource Panel.EmptyState}">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasItems, ElementName=LstSelectedAttachments}" Value="False">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AddEntry.ReferenceTypeCombo"
               TargetType="ComboBox"
               BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>

        <Style x:Key="AddEntry.ReportActionButton"
               TargetType="Button"
               BasedOn="{StaticResource Button.CompactSubtle}">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource Animation.FadeIn}"/>
                </EventTrigger>
            </Grid.Triggers>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,8"
                    Style="{StaticResource Panel.Advisor}">
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource Badge.Icon.Emphasis}">
                        <Path Data="{StaticResource Icon_Geometry_Advisor}" Style="{StaticResource Path_SectionIcon}"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text_Section}"
                                   Text="مسار الإدخال الموحد"/>
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource Text_Body}"
                                   Text="{Binding FormHint}"/>
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource Text_Muted}"
                                   Text="ابدأ بالبيانات الأساسية ثم المرجع والمرفقات الجديدة. يمكنك التراجع عن الصفحة من زر الإلغاء دون فقدان المسار داخل البرنامج."/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1"
                  Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="MainEntryCard"
                        Grid.Column="0"
                        Style="{StaticResource AddEntry.InnerCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="TxtFormTitle"
                                           Style="{StaticResource Text_H2}"
                                           Text="{Binding FormTitle}"/>
                                <TextBlock x:Name="TxtFormHint"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource Text_Muted}"
                                           Text="{Binding FormHint}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Orientation="Horizontal"
                                        FlowDirection="LeftToRight"
                                        VerticalAlignment="Top">
                                <Button Style="{StaticResource Button.Subtle}"
                                        Click="Cancel_Click"
                                        Content="إلغاء"/>
                                <Button Margin="8,0,0,0"
                                        Style="{StaticResource Button.Primary}"
                                        Click="Save_Click"
                                        Content="حفظ الضمان"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1"
                              Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Style="{StaticResource AddEntry.FieldHost}">
                                <TextBlock Style="{StaticResource AddEntry.FieldLabel}" Text="رقم الضمان"/>
                                <TextBox x:Name="TxtGuaranteeNo"
                                         Text="{Binding GuaranteeNo, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock x:Name="HintGuaranteeNo"
                                           Style="{StaticResource AddEntry.FieldHint}"
                                           Text="{Binding GuaranteeNoHint}"
                                           Visibility="{Binding HasGuaranteeNoHint, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2"
                                        Style="{StaticResource AddEntry.FieldHost}">
                                <TextBlock Style="{StaticResource AddEntry.FieldLabel}" Text="المبلغ"/>
                                <TextBox x:Name="TxtAmount"
                                         Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock x:Name="HintAmount"
                                           Style="{StaticResource AddEntry.FieldHint}"
                                           Text="{Binding AmountHint}"
                                           Visibility="{Binding HasAmountHint, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Style="{StaticResource AddEntry.FieldHost}">
                                <TextBlock Style="{StaticResource AddEntry.FieldLabel}" Text="المورد"/>
                                <TextBox x:Name="TxtSupplier"
                                         Text="{Binding Supplier, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock x:Name="HintSupplier"
                                           Style="{StaticResource AddEntry.FieldHint}"
                                           Text="{Binding SupplierHint}"
                                           Visibility="{Binding HasSupplierHint, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1"
                                        Grid.Column="2"
                                        Style="{StaticResource AddEntry.FieldHost}">
                                <TextBlock Style="{StaticResource AddEntry.FieldLabel}" Text="البنك"/>
                                <TextBox x:Name="TxtBank"
                                         Text="{Binding Bank, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock x:Name="HintBank"
                                           Style="{StaticResource AddEntry.FieldHint}"
                                           Text="{Binding BankHint}"
                                           Visibility="{Binding HasBankHint, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Style="{StaticResource AddEntry.FieldHost}">
                                <TextBlock Style="{StaticResource AddEntry.FieldLabel}" Text="نوع الضمان"/>
                                <TextBox x:Name="TxtType"
                                         Text="{Binding GuaranteeType, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2"
                                        Grid.Column="2"
                                        Style="{StaticResource AddEntry.FieldHost}">
                                <TextBlock Style="{StaticResource AddEntry.FieldLabel}" Text="الجهة المستفيدة"/>
                                <TextBox x:Name="TxtBeneficiary"
                                         Text="{Binding Beneficiary, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3"
                                        Style="{StaticResource AddEntry.FieldHost}">
                                <TextBlock Style="{StaticResource AddEntry.FieldLabel}" Text="نوع المرجع"/>
                                <ComboBox x:Name="CmbReferenceType"
                                          Style="{StaticResource AddEntry.ReferenceTypeCombo}"
                                          ItemsSource="{Binding ReferenceTypeOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedReferenceType, Mode=TwoWay}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="3"
                                        Grid.Column="2"
                                        Style="{StaticResource AddEntry.FieldHost}">
                                <TextBlock Style="{StaticResource AddEntry.FieldLabel}" Text="تاريخ الانتهاء"/>
                                <DatePicker x:Name="DateExpiry"
                                            SelectedDate="{Binding ExpiryDate, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="4"
                                        Grid.ColumnSpan="3"
                                        Style="{StaticResource AddEntry.FieldHost}">
                                <TextBlock Style="{StaticResource AddEntry.FieldLabel}" Text="رقم المرجع"/>
                                <TextBox x:Name="TxtReferenceNumber"
                                         Text="{Binding ReferenceNumber, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="5"
                                        Grid.ColumnSpan="3">
                                <TextBlock Style="{StaticResource AddEntry.FieldLabel}" Text="ملاحظات"/>
                                <TextBox x:Name="TxtNotes"
                                         Height="60"
                                         AcceptsReturn="True"
                                         Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap"
                                         VerticalContentAlignment="Top"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2">
                    <Border Height="{Binding ActualHeight, ElementName=MainEntryCard}"
                            Style="{StaticResource AddEntry.InnerCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Text_Section}"
                                               Text="المرفقات الجديدة"/>
                                    <TextBlock x:Name="TxtAttachmentSummary"
                                               Margin="0,4,0,0"
                                               Style="{StaticResource Text_Muted}"
                                               Text="{Binding AttachmentSummary}"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Top"
                                        Click="BrowseAttachments_Click"
                                        Content="إرفاق ملفات"/>
                            </Grid>

                            <Grid Grid.Row="1"
                                  Margin="0,12,0,0">
                                <ListBox x:Name="LstSelectedAttachments"
                                         ItemsSource="{Binding SelectedAttachmentNames}"
                                         ItemContainerStyle="{StaticResource AddEntry.AttachmentItem}"
                                         Style="{StaticResource AddEntry.AttachmentList}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding}"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        Padding="10,0"
                                                        Style="{StaticResource Button.Subtle}"
                                                        Tag="{Binding}"
                                                        Click="RemoveAttachment_Click"
                                                        Content="إزالة"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel Style="{StaticResource AddEntry.AttachmentEmptyState}">
                                    <Path Data="{StaticResource Icon_Geometry_Attachment}"/>
                                    <TextBlock Text="لا توجد ملفات جديدة مرفقة حتى الآن."/>
                                    <TextBlock Margin="0,8,0,0" Text="أضف الملفات الآن إذا أردت أن تُحفظ مع عملية الإدخال أو التعديل الحالية."/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Margin="0,24,0,0" Style="{StaticResource AddEntry.InnerCard}">
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource Text_Section}"
                               Text="التقارير السريعة"/>
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource Text_Muted}"
                               Text="يمكنك تصدير التقارير العشرة مباشرة من الصفحة الرئيسية اعتمادًا على البيانات المحفوظة الحالية."/>
                </StackPanel>

                <primitives:UniformGrid Grid.Row="1"
                                        Margin="-4,16,-4,-4"
                                        Columns="4"
                                        FlowDirection="RightToLeft">
                        <Border Style="{StaticResource AddEntry.ReportCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid FlowDirection="LeftToRight">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{StaticResource AddEntry.ReportActionButton}"
                                            Tag="portfolio.all"
                                            Click="RunWorkspaceReport_Click"
                                            Content="تصدير الآن"/>
                                    <TextBlock Grid.Column="2"
                                               Style="{StaticResource AddEntry.ReportTitle}"
                                               Text="المحفظة الكاملة"/>
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="2"
                                               Grid.ColumnSpan="3"
                                               Style="{StaticResource AddEntry.ReportSummary}"
                                               Text="تصدير قائمة الضمانات كما هي الآن."/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource AddEntry.ReportCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid FlowDirection="LeftToRight">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{StaticResource AddEntry.ReportActionButton}"
                                            Tag="portfolio.summary"
                                            Click="RunWorkspaceReport_Click"
                                            Content="تصدير الآن"/>
                                    <TextBlock Grid.Column="2"
                                               Style="{StaticResource AddEntry.ReportTitle}"
                                               Text="ملخص المحفظة"/>
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="2"
                                               Grid.ColumnSpan="3"
                                               Style="{StaticResource AddEntry.ReportSummary}"
                                               Text="مخرج تنفيذي يجمع الضمانات والطلبات."/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource AddEntry.ReportCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid FlowDirection="LeftToRight">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{StaticResource AddEntry.ReportActionButton}"
                                            Tag="portfolio.expiring"
                                            Click="RunWorkspaceReport_Click"
                                            Content="تصدير الآن"/>
                                    <TextBlock Grid.Column="2"
                                               Style="{StaticResource AddEntry.ReportTitle}"
                                               Text="قريب الانتهاء"/>
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="2"
                                               Grid.ColumnSpan="3"
                                               Style="{StaticResource AddEntry.ReportSummary}"
                                               Text="الضمانات التي تقترب من نهاية المدة."/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource AddEntry.ReportCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid FlowDirection="LeftToRight">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{StaticResource AddEntry.ReportActionButton}"
                                            Tag="portfolio.expired"
                                            Click="RunWorkspaceReport_Click"
                                            Content="تصدير الآن"/>
                                    <TextBlock Grid.Column="2"
                                               Style="{StaticResource AddEntry.ReportTitle}"
                                               Text="منتهية وتحتاج متابعة"/>
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="2"
                                               Grid.ColumnSpan="3"
                                               Style="{StaticResource AddEntry.ReportSummary}"
                                               Text="الضمانات المنتهية زمنيًا التي ما زالت بحاجة إلى إجراء تشغيلي."/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource AddEntry.ReportCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid FlowDirection="LeftToRight">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{StaticResource AddEntry.ReportActionButton}"
                                            Tag="portfolio.no-attachments"
                                            Click="RunWorkspaceReport_Click"
                                            Content="تصدير الآن"/>
                                    <TextBlock Grid.Column="2"
                                               Style="{StaticResource AddEntry.ReportTitle}"
                                               Text="الضمانات بلا مرفقات"/>
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="2"
                                               Grid.ColumnSpan="3"
                                               Style="{StaticResource AddEntry.ReportSummary}"
                                               Text="السجلات الحالية التي لا تحتوي على أي مرفقات محفوظة."/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource AddEntry.ReportCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid FlowDirection="LeftToRight">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{StaticResource AddEntry.ReportActionButton}"
                                            Tag="requests.pending"
                                            Click="RunWorkspaceReport_Click"
                                            Content="تصدير الآن"/>
                                    <TextBlock Grid.Column="2"
                                               Style="{StaticResource AddEntry.ReportTitle}"
                                               Text="الطلبات المعلقة"/>
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="2"
                                               Grid.ColumnSpan="3"
                                               Style="{StaticResource AddEntry.ReportSummary}"
                                               Text="كل الطلبات التي ما زالت بانتظار المعالجة أو الرد."/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource AddEntry.ReportCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid FlowDirection="LeftToRight">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Column="0"
                                            Style="{StaticResource AddEntry.ReportActionButton}"
                                            Tag="daily.followup"
                                            Click="RunWorkspaceReport_Click"
                                            Content="تصدير الآن"/>
                                    <TextBlock Grid.Column="2"
                                               Style="{StaticResource AddEntry.ReportTitle}"
                                               Text="متابعة يومية"/>
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="2"
                                               Grid.ColumnSpan="3"
                                               Style="{StaticResource AddEntry.ReportSummary}"
                                               Text="مخرج متابعة يومية يجمع أهم الضمانات والطلبات."/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource AddEntry.ReportCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
