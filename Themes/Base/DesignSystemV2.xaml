<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:nav="clr-namespace:GuaranteeManager.Themes.Base"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- 
        DESIGN SYSTEM V2 - EXPERIMENTAL MODULE
        Frozen resources for maximum performance.
    -->

    <!-- 1. Iconography Tokens -->
    <sys:Double x:Key="Icon_Size_Small">14</sys:Double>
    <sys:Double x:Key="Icon_Size_Normal">18</sys:Double>
    <sys:Double x:Key="Icon_Size_Large">24</sys:Double>
    <sys:Double x:Key="Icon_Size_Hero">48</sys:Double>
    <FontFamily x:Key="Font_Icons">Segoe MDL2 Assets</FontFamily>

    <!-- 2. Interactive State Brushes (Frozen for speed) -->
    <SolidColorBrush x:Key="State_Focus_Border" Color="{StaticResource Brand_Emerald}" po:Freeze="True"/>
    <SolidColorBrush x:Key="State_Error_Border" Color="#E53E3E" po:Freeze="True"/>
    <SolidColorBrush x:Key="State_Disabled_Bg" Color="#F0F0F0" po:Freeze="True"/>
    <SolidColorBrush x:Key="State_Disabled_Text" Color="#A0A0A0" po:Freeze="True"/>

    <!-- 3. Micro-Animations (Storyboards) -->
    <Storyboard x:Key="Animation.FadeIn">
        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0" To="1" Duration="0:0:0.4">
            <DoubleAnimation.EasingFunction>
                <QuadraticEase EasingMode="EaseOut"/>
            </DoubleAnimation.EasingFunction>
        </DoubleAnimation>
    </Storyboard>

    <!-- 4. Global Interactive Enhancements (Overriding Base Styles safely) -->
    
    <!-- Focus Style for Inputs -->
    <Style x:Key="FocusVisual.Rounded" TargetType="Control">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border BorderBrush="{StaticResource State_Focus_Border}"
                            BorderThickness="1.5"
                            CornerRadius="{StaticResource Corner_Inner}"
                            Margin="-2"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Empty State Template -->
    <Style x:Key="Panel.EmptyState" TargetType="StackPanel">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="40"/>
        <Style.Resources>
            <Style TargetType="TextBlock" BasedOn="{StaticResource Text_Muted}">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="TextAlignment" Value="Center"/>
            </Style>
            <Style TargetType="Path">
                <Setter Property="Width" Value="{StaticResource Icon_Size_Hero}"/>
                <Setter Property="Height" Value="{StaticResource Icon_Size_Hero}"/>
                <Setter Property="Fill" Value="{StaticResource Brush_Text_Muted}"/>
                <Setter Property="Opacity" Value="0.4"/>
                <Setter Property="Margin" Value="0,0,0,16"/>
                <Setter Property="Stretch" Value="Uniform"/>
            </Style>
        </Style.Resources>
    </Style>

    <!-- 5. Navigation Active State (Enhancement) -->
    <Style x:Key="Button.Nav.V2" TargetType="Button" BasedOn="{StaticResource Button.Nav}">
        <Style.Triggers>
            <!-- Using Attached Property for state instead of Tag -->
            <Trigger Property="nav:Nav.IsActive" Value="True">
                <Setter Property="Background" Value="{StaticResource Brand_Emerald}"/>
                <Setter Property="Foreground" Value="{StaticResource Text_OnBrand}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
