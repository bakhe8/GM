    <Style x:Key="IconText.Small" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font_Icons}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{StaticResource Text_Secondary}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <Style x:Key="IconText.Regular" TargetType="TextBlock" BasedOn="{StaticResource IconText.Small}">
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="Path_SectionIcon" TargetType="Path">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="Stroke" Value="{StaticResource Text_Secondary}"/>
        <Setter Property="StrokeThickness" Value="1.6"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="Path_ButtonIcon" TargetType="Path" BasedOn="{StaticResource Path_SectionIcon}">
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>
</ResourceDictionary>
