<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="Button.Chrome" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource Corner_Inner}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Surface_Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{StaticResource Surface_Card_White}"/>
    </Style>

    <Style x:Key="Button.WorkspaceSecondary" TargetType="Button">
        <Setter Property="Height" Value="{DynamicResource Size_Interactive_Height}"/>
        <Setter Property="MinHeight" Value="{DynamicResource Size_Interactive_Height}"/>
        <Setter Property="MinWidth" Value="88"/>
        <Setter Property="Padding" Value="{StaticResource Space_Padding_Button}"/>
        <Setter Property="Foreground" Value="{StaticResource Text_Primary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Corner_Inner}">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Brand_Emerald}"/>
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Surface_Active}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Brand_Emerald_12}"/>
                            <Setter TargetName="Chrome" Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="1"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.48"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource Button.WorkspaceSecondary}"/>

    <Style x:Key="Button.Primary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource Brand_Emerald}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brand_Emerald}"/>
        <Setter Property="Foreground" Value="{StaticResource Text_OnBrand}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#005238"/>
                <Setter Property="BorderBrush" Value="#005238"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#003D2A"/>
                <Setter Property="BorderBrush" Value="#003D2A"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="Button.Ghost" TargetType="Button" BasedOn="{StaticResource Button.WorkspaceSecondary}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style x:Key="Button.Subtle" TargetType="Button" BasedOn="{StaticResource Button.WorkspaceSecondary}"/>

    <Style x:Key="Button.CompactSubtle" TargetType="Button" BasedOn="{StaticResource Button.Subtle}">
        <Setter Property="Height" Value="26"/>
        <Setter Property="MinHeight" Value="26"/>
        <Setter Property="MinWidth" Value="70"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="FontSize" Value="11.5"/>
    </Style>

    <Style x:Key="Button.Nav" TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
        <Setter Property="Height" Value="{DynamicResource Size_Interactive_Height}"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Corner_Solid}"
                            SnapsToDevicePixels="True"/>
                        <!-- Adding a separate overlay for hover and press effects -->
                        <Border x:Name="StateOverlay"
                                Background="Transparent"
                                CornerRadius="0"
                                IsHitTestVisible="False"/>
                        
                        <ContentPresenter x:Name="Content"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          Panel.ZIndex="1"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Case 1: Hovering over a Transparent (Inactive) button - made slightly darker -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="Background" Value="Transparent"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="StateOverlay" Property="Background" Value="{StaticResource Neutral_100}"/>
                        </MultiTrigger>

                        <!-- Case 2: Hovering over an Emerald (Active) button - made slightly darker green -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="Background" Value="{StaticResource Brand_Emerald}"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="StateOverlay" Property="Background" Value="#12000000"/>
                        </MultiTrigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="StateOverlay" Property="Background" Value="#26000000"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.48"/>
                            <Setter TargetName="Content" Property="Opacity" Value="0.48"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Button.TitleBar" TargetType="Button" BasedOn="{StaticResource Button.Ghost}">
        <Setter Property="Width" Value="{DynamicResource Size_TitleBar_Height}"/>
        <Setter Property="MinWidth" Value="{DynamicResource Size_TitleBar_Height}"/>
        <Setter Property="Height" Value="{DynamicResource Size_TitleBar_Height}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource Text_OnBrand}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome"
                            Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#1FFFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#33FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
