<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="Card.Panel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface_Card_White}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Surface_Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource Corner_Inner}"/>
        <Setter Property="Padding" Value="{StaticResource Padding_Card}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="10"
                                  ShadowDepth="1.2"
                                  Direction="270"
                                  Color="Black"
                                  Opacity="0.12"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Card.Compact" TargetType="Border" BasedOn="{StaticResource Card.Panel}">
        <Setter Property="Padding" Value="8"/>
    </Style>

    <Style x:Key="Panel.Advisor" TargetType="Border" BasedOn="{StaticResource Card.Panel}">
        <Setter Property="Background" Value="{StaticResource Neutral_025}"/>
    </Style>

    <Style x:Key="Panel.Feedback" TargetType="Border" BasedOn="{StaticResource Card.Panel}">
        <Setter Property="Background" Value="{StaticResource Surface_Active}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brand_Emerald_20}"/>
    </Style>

    <Style x:Key="MetricStrip.Panel" TargetType="Border" BasedOn="{StaticResource Card.Panel}">
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="Tile.Neutral" TargetType="Border" BasedOn="{StaticResource Card.Compact}"/>

    <Style x:Key="Tile.Info" TargetType="Border" BasedOn="{StaticResource Tile.Neutral}">
        <Setter Property="Background" Value="{StaticResource Surface_Active}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brand_Emerald_20}"/>
    </Style>

    <Style x:Key="Tile.Success" TargetType="Border" BasedOn="{StaticResource Tile.Neutral}">
        <Setter Property="Background" Value="{StaticResource Brand_Emerald_12}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brand_Emerald_20}"/>
    </Style>

    <Style x:Key="Badge.Icon.Base" TargetType="Border">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource Corner_Inner}"/>
    </Style>

    <Style x:Key="Badge.Icon.Emphasis" TargetType="Border" BasedOn="{StaticResource Badge.Icon.Base}">
        <Setter Property="Background" Value="{StaticResource Brand_Emerald_12}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brand_Emerald_20}"/>
    </Style>

    <Style x:Key="Badge.Icon.Neutral" TargetType="Border" BasedOn="{StaticResource Badge.Icon.Base}">
        <Setter Property="Background" Value="{StaticResource Neutral_050}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Surface_Border}"/>
    </Style>

    <Style x:Key="Tile.Label" TargetType="TextBlock" BasedOn="{StaticResource Text_Caption}">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="Tile.Value" TargetType="TextBlock" BasedOn="{StaticResource Text_Body}">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Text_Primary}"/>
    </Style>

    <Style x:Key="MetricStrip.ItemStack" TargetType="StackPanel">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="24,0"/>
    </Style>

    <Style x:Key="MetricStrip.Separator" TargetType="Rectangle">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Fill" Value="{StaticResource Surface_Border}"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Margin" Value="0,16"/>
    </Style>

    <Style x:Key="ListBox.Flat" TargetType="ListBox">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Background" Value="{StaticResource Surface_Card_White}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Surface_Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FlowDirection" Value="RightToLeft"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Corner_Inner}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Brand_Emerald}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Brand_Emerald_12}"/>
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Brand_Emerald}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="CanUserResizeRows" Value="False"/>
        <Setter Property="RowHeight" Value="31"/>
        <Setter Property="ColumnHeaderHeight" Value="34"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Neutral_150}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource Neutral_150}"/>
        <Setter Property="RowHeaderWidth" Value="0"/>
        <Setter Property="BorderBrush" Value="{StaticResource Surface_Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{StaticResource Surface_Card_White}"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
        <Setter Property="ColumnWidth" Value="*"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource Neutral_050}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Surface_Border}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource Text_Primary}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Grid>
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="{StaticResource Surface_Card_White}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Style.Triggers>
            <Trigger Property="AlternationIndex" Value="1">
                <Setter Property="Background" Value="{StaticResource Neutral_025}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Surface_Active}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Brand_Emerald_12}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="BorderBrush" Value="{StaticResource Neutral_150}"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{StaticResource Text_Primary}"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DataGridText.Base" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
    </Style>

    <Style x:Key="DataGridText.Rtl" TargetType="TextBlock" BasedOn="{StaticResource DataGridText.Base}">
        <Setter Property="TextAlignment" Value="Right"/>
    </Style>

    <Style x:Key="DataGridText.Ltr" TargetType="TextBlock" BasedOn="{StaticResource DataGridText.Rtl}">
        <Setter Property="FlowDirection" Value="LeftToRight"/>
        <Setter Property="TextAlignment" Value="Left"/>
    </Style>

    <Style x:Key="DataGridText.Center" TargetType="TextBlock" BasedOn="{StaticResource DataGridText.Rtl}">
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

</ResourceDictionary>
