<UserControl x:Class="GuaranteeManager.Views.TodayDeskView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Metric Bar -->
        <Border Grid.Row="0"
                Style="{StaticResource MetricStrip.Panel}"
                CornerRadius="{StaticResource Corner_Inner}">
            <Grid Height="80">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Style="{StaticResource MetricStrip.ItemStack}">
                    <TextBlock Style="{StaticResource Text_Caption}" Text="إجمالي الضمانات"/>
                    <TextBlock Style="{StaticResource Text_Metric}" Text="{Binding TotalGuarantees}" Margin="0,4,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Style="{StaticResource MetricStrip.Separator}"/>

                <StackPanel Grid.Column="2" Style="{StaticResource MetricStrip.ItemStack}">
                    <TextBlock Style="{StaticResource Text_Caption}" Text="منتهية وتحتاج متابعة"/>
                    <TextBlock Style="{StaticResource Text_Metric}" Text="{Binding ExpiredFollowUp}" Margin="0,4,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="3" Style="{StaticResource MetricStrip.Separator}"/>

                <StackPanel Grid.Column="4" Style="{StaticResource MetricStrip.ItemStack}">
                    <TextBlock Style="{StaticResource Text_Caption}" Text="قريب الانتهاء"/>
                    <TextBlock Style="{StaticResource Text_Metric}" Text="{Binding ExpiringSoon}" Margin="0,4,0,0"/>
                </StackPanel>

                <Rectangle Grid.Column="5" Style="{StaticResource MetricStrip.Separator}"/>

                <StackPanel Grid.Column="6" Style="{StaticResource MetricStrip.ItemStack}">
                    <TextBlock Style="{StaticResource Text_Caption}" Text="طلبات معلقة"/>
                    <TextBlock Style="{StaticResource Text_Metric}" Text="{Binding PendingRequestsCount}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource Card.Panel}"
                    CornerRadius="{StaticResource Corner_Inner}"
                    MinHeight="480">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource Text_Section}"
                                   Text="ضمانات تحتاج انتباهًا"/>
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource Text_Muted}"
                                   Text="الضمانات المنتهية أو القريبة من الانتهاء مرتبة حسب الإلحاح."/>
                    </StackPanel>

                    <DataGrid x:Name="GridUrgentGuarantees"
                               Grid.Row="1"
                               Margin="0,16,0,16"
                               AutoGenerateColumns="False"
                               IsReadOnly="True"
                               ItemsSource="{Binding UrgentGuarantees}"
                               SelectedItem="{Binding SelectedUrgentGuarantee, Mode=TwoWay}"
                               PreviewMouseRightButtonDown="GridUrgentGuarantees_PreviewMouseRightButtonDown"
                               ContextMenuOpening="GridUrgentGuarantees_ContextMenuOpening"
                               MouseDoubleClick="GridUrgentGuarantees_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="رقم الضمان" Binding="{Binding GuaranteeNo}" Width="*" MinWidth="100" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                            <DataGridTextColumn Header="المورد" Binding="{Binding Supplier}" Width="1.3*" MinWidth="120" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                            <DataGridTextColumn Header="البنك" Binding="{Binding Bank}" Width="1.1*" MinWidth="110" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                            <DataGridTextColumn Header="الانتهاء" Binding="{Binding ExpiryDate, StringFormat=yyyy-MM-dd}" Width="*" MinWidth="95" ElementStyle="{StaticResource DataGridText.Center}"/>
                            <DataGridTextColumn Header="الحالة" Binding="{Binding StatusLabel}" Width="*" MinWidth="90" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="2"
                            Style="{StaticResource Button.Primary}"
                            Click="OpenUrgentGuarantee_Click"
                            Content="فتح الضمان المحدد"/>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource Card.Panel}"
                    CornerRadius="{StaticResource Corner_Inner}"
                    MinHeight="480">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource Text_Section}"
                                   Text="طلبات تحتاج متابعة"/>
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource Text_Muted}"
                                   Text="الطلبات قيد الانتظار أو التي تنتظر مستندات الرد."/>
                    </StackPanel>

                    <DataGrid x:Name="GridPendingRequests"
                               Grid.Row="1"
                               Margin="0,16,0,16"
                               AutoGenerateColumns="False"
                               IsReadOnly="True"
                               ItemsSource="{Binding PendingRequests}"
                               SelectedItem="{Binding SelectedPendingRequest, Mode=TwoWay}"
                               PreviewMouseRightButtonDown="GridPendingRequests_PreviewMouseRightButtonDown"
                               ContextMenuOpening="GridPendingRequests_ContextMenuOpening"
                               MouseDoubleClick="GridPendingRequests_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="رقم الضمان" Binding="{Binding GuaranteeNo}" Width="*" MinWidth="100" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                            <DataGridTextColumn Header="المورد" Binding="{Binding Supplier}" Width="1.2*" MinWidth="120" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                            <DataGridTextColumn Header="النوع" Binding="{Binding Request.TypeLabel}" Width="*" MinWidth="95" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                            <DataGridTextColumn Header="الحالة" Binding="{Binding Request.StatusLabel}" Width="*" MinWidth="90" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                            <DataGridTextColumn Header="التاريخ" Binding="{Binding RequestDateLabel}" Width="*" MinWidth="95" ElementStyle="{StaticResource DataGridText.Center}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="2"
                            Style="{StaticResource Button.Primary}"
                            Click="OpenPendingRequest_Click"
                            Content="فتح ملف الطلب المحدد"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="{DynamicResource Space_Section_Top}"
                Style="{StaticResource Card.Panel}"
                Height="80"
                Padding="16,0"
                CornerRadius="{StaticResource Corner_Inner}">
            <Grid VerticalAlignment="Center"
                  FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource Button.Primary}"
                            Click="NewGuarantee_Click"
                            Width="140"
                            Content="ضمان جديد"/>
                    <Button Margin="12,0,0,0"
                            Style="{StaticResource Button.Subtle}"
                            Click="OpenPortfolio_Click"
                            Content="فتح الضمانات"/>
                    <Button Margin="12,0,0,0"
                            Style="{StaticResource Button.Subtle}"
                            Click="OpenRequests_Click"
                            Content="فتح الطلبات"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            FlowDirection="RightToLeft"
                            HorizontalAlignment="Stretch">
                    <TextBlock Style="{StaticResource Text_Section}"
                               HorizontalAlignment="Stretch"
                               TextAlignment="Left"
                               Text="خطوات سريعة"/>
                    <TextBlock Margin="0,2,0,0"
                               Style="{StaticResource Text_Muted}"
                               HorizontalAlignment="Stretch"
                               TextAlignment="Left"
                               Text="ابدأ بإجراء جديد أو انتقل مباشرة إلى مساحة العمل."/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
