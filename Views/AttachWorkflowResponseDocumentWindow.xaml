<Window x:Class="GuaranteeManager.Views.AttachWorkflowResponseDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="إلحاق مستند رد البنك"
        Height="430"
        Width="760"
        MinHeight="400"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Surface_Bg_Light}"
        FlowDirection="RightToLeft"
        FontFamily="{StaticResource Font_Primary}">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Panel.Advisor}"
                Padding="12"
                Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource Badge.Icon.Emphasis}">
                    <Path Data="{StaticResource Icon_Geometry_Attachment}" Style="{StaticResource Path_SectionIcon}"/>
                </Border>
                <StackPanel>
                    <TextBlock Text="إلحاق مستند رد البنك" Style="{StaticResource Text_H1}" Margin="0"/>
                    <TextBlock Text="استخدم هذه النافذة عندما يكون الطلب مغلقًا أو منفذًا، لكن مستند رد البنك وصل لاحقًا وتريد حفظه على نفس الطلب."
                               Style="{StaticResource Text_Muted}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card.Panel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="رقم الضمان" Style="{StaticResource InputLabel}"/>
                <TextBlock x:Name="TxtGuaranteeNo" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="نوع الطلب" Style="{StaticResource InputLabel}"/>
                <TextBlock x:Name="TxtRequestType" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,8" Text="حالة الطلب" Style="{StaticResource InputLabel}"/>
                <TextBlock x:Name="TxtRequestStatus" Grid.Row="1" Grid.Column="1" Margin="0,8,0,8" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,8,0,8" Text="رقم الطلب" Style="{StaticResource InputLabel}"/>
                <TextBlock x:Name="TxtRequestSequence" Grid.Row="1" Grid.Column="3" Margin="0,8,0,8" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,8" Text="مستند رد البنك" Style="{StaticResource InputLabel}"/>
                <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,8,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtResponseFile" IsReadOnly="True"/>
                    <Button x:Name="BtnBrowseResponseFile" Grid.Column="1" Click="BrowseFile_Click" Style="{StaticResource Button.Subtle}" Margin="8,0,0,0"/>
                </Grid>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,0,0" Text="ملاحظة إضافية" Style="{StaticResource InputLabel}"/>
                <TextBox x:Name="TxtAdditionalNotes"
                         Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                         Margin="0,8,0,0"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="120"
                         Padding="8"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    FlowDirection="LeftToRight"
                    Margin="0,8,0,0">
            <Button x:Name="BtnSave" Click="Save_Click" Style="{StaticResource Button.Primary}"/>
            <Button x:Name="BtnCancel" Click="Cancel_Click" Margin="8,0,0,0" Style="{StaticResource Button.Subtle}"/>
        </StackPanel>
    </Grid>
</Window>
