<UserControl x:Class="GuaranteeManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="{DynamicResource Space_Shell_Outer}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource MetricStrip.Panel}"
                    CornerRadius="{StaticResource Corner_Inner}">
                <Grid Height="80">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Style="{StaticResource MetricStrip.ItemStack}">
                        <TextBlock Style="{StaticResource Text_Caption}" Text="عدد الضمانات"/>
                        <TextBlock Margin="0,4,0,0" Style="{StaticResource Text_Metric}" Text="{Binding GuaranteeCount}"/>
                    </StackPanel>

                    <Rectangle Grid.Column="1" Style="{StaticResource MetricStrip.Separator}"/>

                    <StackPanel Grid.Column="2" Style="{StaticResource MetricStrip.ItemStack}">
                        <TextBlock Style="{StaticResource Text_Caption}" Text="عدد الطلبات"/>
                        <TextBlock Margin="0,4,0,0" Style="{StaticResource Text_Metric}" Text="{Binding RequestCount}"/>
                    </StackPanel>

                    <Rectangle Grid.Column="3" Style="{StaticResource MetricStrip.Separator}"/>

                    <StackPanel Grid.Column="4" Style="{StaticResource MetricStrip.ItemStack}">
                        <TextBlock Style="{StaticResource Text_Caption}" Text="عدد المرفقات"/>
                        <TextBlock Margin="0,4,0,0" Style="{StaticResource Text_Metric}" Text="{Binding AttachmentCount}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="{DynamicResource Space_Section_Top}"
                    Style="{StaticResource Card.Panel}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text_Section}" Text="الإعدادات والتشغيل"/>
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource Text_Muted}"
                               Text="من هذه الشاشة يمكن إدارة النسخ الاحتياطي، الوصول إلى مجلدات التشغيل، ومهام البيئة التجريبية ضمن بنية موحدة وواضحة."/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" Margin="{DynamicResource Space_Section_Top}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource Card.Panel}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text_Section}" Text="النسخ الاحتياطي"/>
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource Text_Body}" Text="أنشئ نسخة احتياطية يدوية من قاعدة البيانات أو استرجع نسخة محفوظة. عند الاسترجاع سيُنشئ النظام نسخة أمان قبل الاستبدال."/>
                            <Button Margin="0,12,0,0" Style="{StaticResource Button.Primary}" Click="ManualBackup_Click" Content="إنشاء نسخة احتياطية"/>
                            <Button Margin="0,8,0,0" Style="{StaticResource Button.Subtle}" Click="RestoreBackup_Click" Content="استرجاع نسخة احتياطية"/>
                            <TextBlock Margin="0,12,0,0" Style="{StaticResource Text_Muted}" Text="{Binding LastBackupPath}" TextWrapping="Wrap"/>
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource Text_Muted}" Text="{Binding LastRestorePath}" TextWrapping="Wrap"/>
                            
                            <Separator Margin="0,16,0,16"/>
                            
                            <TextBlock Style="{StaticResource Text_Body}" Text="أنشئ حزمة محمولة تتضمن قاعدة البيانات والمرفقات ووثائق الطلبات، محمية بعبارة مرور لتعمل على جهاز آخر."/>
                            <Button Margin="0,12,0,0" Style="{StaticResource Button.Primary}" Click="PortableBackup_Click" Content="إنشاء حزمة محمولة"/>
                            <Button Margin="0,8,0,0" Style="{StaticResource Button.Subtle}" Click="RestorePortableBackup_Click" Content="استرجاع حزمة محمولة"/>
                            <TextBlock Margin="0,12,0,0" Style="{StaticResource Text_Muted}" Text="{Binding LastPortablePackagePath}" TextWrapping="Wrap"/>
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource Text_Muted}" Text="{Binding LastPortableRestorePath}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,8,0,0" Style="{StaticResource Card.Panel}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text_Section}" Text="مجلدات التشغيل"/>
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource Text_Caption}" Text="قاعدة البيانات"/>
                            <TextBlock Margin="0,4,0,0" Style="{StaticResource Text_Muted}" Text="{Binding DatabasePath}" TextWrapping="Wrap"/>
                            <TextBlock Margin="0,12,0,0" Style="{StaticResource Text_Caption}" Text="المرفقات"/>
                            <TextBlock Margin="0,4,0,0" Style="{StaticResource Text_Muted}" Text="{Binding AttachmentsPath}" TextWrapping="Wrap"/>
                            <TextBlock Margin="0,12,0,0" Style="{StaticResource Text_Caption}" Text="الطلبات والردود"/>
                            <TextBlock Margin="0,4,0,0" Style="{StaticResource Text_Muted}" Text="{Binding WorkflowPath}" TextWrapping="Wrap"/>
                            <TextBlock Margin="0,12,0,0" Style="{StaticResource Text_Caption}" Text="السجلات"/>
                            <TextBlock Margin="0,4,0,0" Style="{StaticResource Text_Muted}" Text="{Binding LogsPath}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource Card.Panel}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Text_Section}" Text="فتح المجلدات"/>
                            <TextBlock Margin="0,8,0,0" Style="{StaticResource Text_Body}" Text="افتح مجلدات العمل الرئيسية مباشرة من البرنامج."/>
                            <Button Margin="0,12,0,0" Style="{StaticResource Button.Subtle}" Click="OpenDataFolder_Click" Content="فتح مجلد البيانات"/>
                            <Button Margin="0,8,0,0" Style="{StaticResource Button.Subtle}" Click="OpenAttachmentsFolder_Click" Content="فتح مجلد المرفقات"/>
                            <Button Margin="0,8,0,0" Style="{StaticResource Button.Subtle}" Click="OpenWorkflowFolder_Click" Content="فتح مجلد الطلبات والردود"/>
                            <Button Margin="0,8,0,0" Style="{StaticResource Button.Subtle}" Click="OpenLogsFolder_Click" Content="فتح مجلد السجلات"/>

                            <Separator Margin="0,16,0,16"/>
                            <StackPanel x:Name="DevToolsSection">
                                <TextBlock Style="{StaticResource Text_Section}" Text="تطوير واختبار"/>
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource Text_Body}" Text="قم بتوليد بيانات وهمية (ضمانات، طلبات، تاريخ) لاختبار أداء الواجهات والتصميم."/>
                                <Button Margin="0,12,0,0" Style="{StaticResource Button.Primary}" Click="SeedData_Click" Content="توليد بيانات تجريبية (Seed)"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
