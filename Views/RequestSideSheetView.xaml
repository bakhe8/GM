<UserControl x:Class="GuaranteeManager.Views.RequestSideSheetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="{DynamicResource Space_Padding_SideSheet}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card.Panel}">
            <StackPanel>
                <TextBlock x:Name="TxtRequestTitle"
                           Style="{StaticResource Text_H2}"
                           Text="طلب رقم 1"/>
                <TextBlock x:Name="TxtRequestSummary"
                           Margin="0,4,0,0"
                           Style="{StaticResource Text_Muted}"
                           Text="BG-0000 | المورد | البنك"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="{DynamicResource Space_Section_Top}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource Card.Compact}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text_Caption}" Text="الحالة"/>
                    <TextBlock x:Name="TxtRequestStatus" Margin="0,6,0,0" Style="{StaticResource Text_Section}" Text="قيد الانتظار"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2"
                    Style="{StaticResource Card.Compact}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text_Caption}" Text="النوع"/>
                    <TextBlock x:Name="TxtRequestType" Margin="0,6,0,0" Style="{StaticResource Text_Section}" Text="تمديد"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4"
                    Style="{StaticResource Card.Compact}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Text_Caption}" Text="تاريخ الإنشاء"/>
                    <TextBlock x:Name="TxtRequestDate" Margin="0,6,0,0" Style="{StaticResource Text_Section}" Text="--"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="{DynamicResource Space_Section_Top}"
                Style="{StaticResource Card.Panel}">
            <StackPanel>
                <TextBlock Style="{StaticResource Text_Section}" Text="تفاصيل الطلب"/>
                <TextBlock Margin="0,4,0,0"
                           Style="{StaticResource Text_Muted}"
                           Text="تجمع هذه البطاقة القيم الحالية والمطلوبة، مع الملاحظات وروابط المستندات المرتبطة بالطلب."/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Style="{StaticResource Text_Caption}" Text="القيمة الحالية"/>
                        <TextBlock x:Name="TxtCurrentValue" Margin="0,6,0,0" Style="{StaticResource Text_Section}" Text="--"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource Text_Caption}" Text="القيمة المطلوبة"/>
                        <TextBlock x:Name="TxtRequestedValue" Margin="0,6,0,0" Style="{StaticResource Text_Section}" Text="--"/>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,16,0,16"/>

                <StackPanel>
                    <TextBlock Style="{StaticResource Text_Caption}" Text="ملاحظات الطلب"/>
                    <TextBlock x:Name="TxtNotes"
                               Margin="0,6,0,0"
                               Style="{StaticResource Text_Body}"
                               Text="--"/>
                </StackPanel>

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Style="{StaticResource Button.Primary}"
                            Click="OpenGuarantee_Click"
                            Content="فتح الضمان"/>
                    <Button x:Name="BtnOpenLetter"
                            Grid.Column="2"
                            Style="{StaticResource Button.Subtle}"
                            Click="OpenLetter_Click"
                            Content="خطاب الطلب"/>
                    <Button x:Name="BtnResponseAction"
                            Grid.Column="4"
                            Style="{StaticResource Button.Subtle}"
                            Click="OpenResponse_Click"
                            Content="مستند الرد"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
