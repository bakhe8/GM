<Window x:Class="GuaranteeManager.Views.CreateReplacementRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="طلب استبدال جديد"
        Height="720"
        Width="880"
        MinHeight="680"
        MinWidth="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Surface_Bg_Light}"
        FlowDirection="RightToLeft"
        FontFamily="{StaticResource Font_Primary}">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Panel.Advisor}" Margin="0,0,0,8" Padding="12">
            <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource Badge.Icon.Emphasis}">
                    <Path Data="{StaticResource Icon_Geometry_Advisor}" Style="{StaticResource Path_SectionIcon}"/>
                </Border>
                <StackPanel>
                    <TextBlock Text="طلب استبدال جديد" Style="{StaticResource Text_H1}" Margin="0"/>
                    <TextBlock Text="يسجل الطلب كمعلق، وسيتم إغلاق الضمان الحالي وتفعيل الضمان البديل بعد تسجيل موافقة البنك. هذه النافذة تجمع بيانات الضمان الحالي والبديل في نفس المسار لضمان اكتمال الاستبدال قبل الإرسال."
                               Style="{StaticResource Text_Muted}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                    <Border Style="{StaticResource Tile.Neutral}" Margin="0,8,0,0">
                        <TextBlock Text="ابدأ باختيار الضمان الحالي، ثم أدخل كل بيانات الضمان البديل ومرجعه واسم منشئ الطلب قبل الحفظ."
                                   Style="{StaticResource Text_Caption}"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Current Guarantee Info -->
                <Border Style="{StaticResource Card.Panel}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="الضمان الحالي المراد استبداله" Style="{StaticResource Text_Section}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="اختر الضمان" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CmbGuarantee" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                                      DisplayMemberPath="WorkflowDisplayLabel"
                                      SelectionChanged="Guarantee_SelectionChanged"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="المورد الحالي" Style="{StaticResource InputLabel}" Margin="0,8,0,0"/>
                            <TextBlock x:Name="TxtCurrentSupplier" Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brand_Slate}"/>

                            <TextBlock Grid.Row="1" Grid.Column="2" Text="البنك الحالي" Style="{StaticResource InputLabel}" Margin="0,8,0,0"/>
                            <TextBlock x:Name="TxtCurrentBank" Grid.Row="1" Grid.Column="3" Margin="0,8,0,0" VerticalAlignment="Center" Foreground="{StaticResource Brand_Slate}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Replacement Guarantee Data -->
                <Border Style="{StaticResource Card.Panel}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="بيانات الضمان البديل الجديد" Style="{StaticResource Text_Section}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Row 0: No & Supplier -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="رقم الضمان" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtReplacementGuaranteeNo" Grid.Row="0" Grid.Column="1" Margin="0,0,8,8"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="المورد" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtReplacementSupplier" Grid.Row="0" Grid.Column="3" Margin="0,0,0,8"/>

                            <!-- Row 1: Bank & Amount -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="البنك" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtReplacementBank" Grid.Row="1" Grid.Column="1" Margin="0,0,8,8"/>

                            <TextBlock Grid.Row="1" Grid.Column="2" Text="المبلغ" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtReplacementAmount" Grid.Row="1" Grid.Column="3" Margin="0,0,0,8"/>

                            <!-- Row 2: Expiry & Type -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="تاريخ الانتهاء" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                            <DatePicker x:Name="DateReplacementExpiry" Grid.Row="2" Grid.Column="1" Margin="0,0,8,8"/>

                            <TextBlock Grid.Row="2" Grid.Column="2" Text="نوع الضمان" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtReplacementGuaranteeType" Grid.Row="2" Grid.Column="3" Margin="0,0,0,8"/>

                            <!-- Row 3: Beneficiary -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="المستفيد" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtReplacementBeneficiary" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,0,8"/>

                            <!-- Row 4: Reference -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="نوع المرجع" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                                <RadioButton x:Name="RadReplacementContract" Content="عقد" IsChecked="True" Margin="0,0,16,0"/>
                                <RadioButton x:Name="RadReplacementPO" Content="تعميد"/>
                            </StackPanel>

                            <TextBlock Grid.Row="4" Grid.Column="2" Text="رقم المرجع" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtReplacementReferenceNumber" Grid.Row="4" Grid.Column="3" Margin="0,0,0,8"/>

                            <!-- Row 5: Created By -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="منشئ الطلب" Style="{StaticResource InputLabel}" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtCreatedBy" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Notes -->
                <Border Style="{StaticResource Card.Panel}">
                    <StackPanel>
                        <TextBlock Text="ملاحظات إضافية" Style="{StaticResource Text_Section}" Margin="0,0,0,8"/>
                        <TextBox x:Name="TxtNotes"
                                  AcceptsReturn="True"
                                  TextWrapping="Wrap"
                                  VerticalScrollBarVisibility="Auto"
                                  MinHeight="80"
                                  Padding="8"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Margin="0,8,0,0">
            <Border Style="{StaticResource Tile.Neutral}">
                <TextBlock x:Name="TxtSaveGuidance"
                           Style="{StaticResource Text_Caption}"
                           Text="أدخل بيانات الضمان البديل واسم منشئ الطلب قبل الحفظ."/>
            </Border>
            <StackPanel Orientation="Horizontal" FlowDirection="LeftToRight">
                <Button x:Name="BtnSave"
                        Content="متابعة إنشاء الطلب"
                        Click="Save_Click"
                        Style="{StaticResource Button.Primary}"/>
                <Button Content="إغلاق دون حفظ"
                        Click="Cancel_Click"
                        Margin="8,0,0,0"
                        Style="{StaticResource Button.Subtle}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
