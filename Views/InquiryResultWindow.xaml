<Window x:Class="GuaranteeManager.Views.InquiryResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="نتيجة الاستعلام"
        Height="720"
        Width="980"
        MinHeight="580"
        MinWidth="820"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Surface_Bg_Light}"
        FlowDirection="RightToLeft"
        FontFamily="{StaticResource Font_Primary}"
        IsVisibleChanged="View_IsVisibleChanged">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Panel.Advisor}" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource Badge.Icon.Emphasis}">
                    <Path Data="{StaticResource Icon_Geometry_Advisor}" Style="{StaticResource Path_SectionIcon}"/>
                </Border>

                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="TxtTitle" Style="{StaticResource Text_H1}" Margin="0" Text="نتيجة الاستعلام"/>
                    <TextBlock x:Name="TxtSubject" Margin="0,4,0,0" Style="{StaticResource Text_Body}" Foreground="{StaticResource Brand_Slate}"/>
                    <TextBlock x:Name="TxtEventDate" Margin="0,4,0,0" Style="{StaticResource Text_Caption}" Foreground="{StaticResource Brand_Slate}" Opacity="0.7"/>
                </StackPanel>

                <TextBlock Grid.Column="2" Text="يعرض جوابًا مباشرًا مع أدلة ومراجع داعمة." Style="{StaticResource Text_Caption}" Foreground="{StaticResource Brand_Slate}" Opacity="0.7" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Panel.Advisor}" Padding="12" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="الجواب المختصر" Style="{StaticResource Tile.Label}" Foreground="{StaticResource Brand_Slate}" Opacity="0.7"/>
                <TextBlock x:Name="TxtAnswer" Margin="0,4,0,0" Style="{StaticResource Text_H2}" TextWrapping="Wrap" Foreground="{StaticResource Brand_Slate}"/>
                <TextBlock x:Name="TxtExplanation" Margin="0,8,0,0" Style="{StaticResource Text_Body}" TextWrapping="Wrap" Foreground="{StaticResource Brand_Slate}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card.Panel}" Padding="12" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="الملفات والمستندات الداعمة" Style="{StaticResource Text_H2}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Margin="0,0,8,0" Style="{StaticResource Tile.Neutral}">
                        <StackPanel>
                            <TextBlock Text="خطاب الطلب" Style="{StaticResource Tile.Label}"/>
                            <TextBlock x:Name="TxtLetterEvidence" Style="{StaticResource Tile.Value}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="0,0,8,0" Style="{StaticResource Tile.Neutral}">
                        <StackPanel>
                            <TextBlock Text="مستند رد البنك" Style="{StaticResource Tile.Label}"/>
                            <TextBlock x:Name="TxtResponseEvidence" Style="{StaticResource Tile.Value}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Margin="0,0,8,0" Style="{StaticResource Tile.Info}">
                        <StackPanel>
                            <TextBlock Text="تقرير الضمان" Style="{StaticResource Tile.Label}"/>
                            <TextBlock x:Name="TxtGuaranteeReportEvidence" Style="{StaticResource Tile.Value}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource Tile.Info}">
                        <StackPanel>
                            <TextBlock Text="تاريخ الضمان" Style="{StaticResource Tile.Label}"/>
                            <TextBlock x:Name="TxtHistoryEvidence" Style="{StaticResource Tile.Value}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource Card.Panel}" Padding="12" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="ملخص الأدلة" Style="{StaticResource Text_H2}" Margin="0,0,0,8"/>
                <ItemsControl x:Name="FactsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="220" Margin="0,0,8,8" Style="{StaticResource Tile.Info}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Label}" Style="{StaticResource Tile.Label}"/>
                                    <TextBlock Text="{Binding Value}" Style="{StaticResource Tile.Value}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource Card.Panel}" Padding="0">
            <Grid>
                <DataGrid x:Name="GridTimeline" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#E6E6E6"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E6E6E6"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#111111"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#111111"/>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="GridTimelineRow_PreviewMouseLeftButtonDown"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding TimestampLabel}" Width="1.2*" MinWidth="130" ElementStyle="{StaticResource DataGridText.Center}"/>
                        <DataGridTextColumn Header="التفاصيل" Binding="{Binding Details}" Width="2.5*" MinWidth="200" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                        <DataGridTextColumn Header="الحدث" Binding="{Binding Title}" Width="1.5*" MinWidth="150" ElementStyle="{StaticResource DataGridText.Rtl}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="5" Style="{StaticResource Panel.Advisor}" Padding="12" Margin="0,8,0,0">
            <StackPanel>
                <TextBlock x:Name="TxtInquiryActionsTitle" Text="ما الذي تريد فعله بعد هذا الجواب؟" Style="{StaticResource Text_H2}" Margin="0"/>
                <TextBlock x:Name="TxtInquiryActionsSummary" Text="الجواب موضح أعلاه، ومن هنا يمكنك فتح الملفات الداعمة المرتبطة أو استخراج التقارير المساندة." Style="{StaticResource Text_Muted}" Margin="0,4,0,8"/>
                <StackPanel x:Name="InquiryActionPanel"/>
            </StackPanel>
        </Border>

        <Border x:Name="LocalStatusBorder" Grid.Row="6" Visibility="Collapsed" Margin="0,8,0,0" Style="{StaticResource Panel.Feedback}">
            <StackPanel>
                <TextBlock Text="آخر نتيجة" Style="{StaticResource Tile.Label}"/>
                <TextBlock x:Name="TxtLocalStatus" Style="{StaticResource Tile.Value}"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Left" FlowDirection="LeftToRight" Margin="0,8,0,0">
            <Button x:Name="BtnClose" Click="Close_Click" Style="{StaticResource Button.Subtle}"/>
        </StackPanel>
    </Grid>
</Window>
