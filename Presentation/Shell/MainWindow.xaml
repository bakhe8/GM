<Window x:Class="GuaranteeManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GuaranteeManager"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#F7F9FC"
        FontFamily="Segoe UI, Tahoma"
        FlowDirection="RightToLeft"
        automation:AutomationProperties.AutomationId="Shell.MainWindow"
        automation:AutomationProperties.Name="إدارة الضمانات البنكية">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Centralized high-quality SVG icons and official presentation themes. -->
                <ResourceDictionary Source="pack://application:,,,/IconsDictionary.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Presentation/Themes/Colors.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Presentation/Themes/Effects.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Presentation/Themes/Converters.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Presentation/Themes/Buttons.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Presentation/Themes/Inputs.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Presentation/Themes/Cards.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Presentation/Themes/Typography.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Presentation/Themes/Tables.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Presentation/Themes/Navigation.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource Brush.Canvas}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource Brush.TopBar}"
                MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
            <Grid FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0">
                    <Button Style="{StaticResource ChromeButton}" Click="CloseButton_Click" Content="X" />
                    <Button Style="{StaticResource ChromeButton}" Click="MaximizeButton_Click" Content="□" automation:AutomationProperties.AutomationId="Shell.MaximizeButton" automation:AutomationProperties.Name="تكبير" />
                    <Button Style="{StaticResource ChromeButton}" Click="MinimizeButton_Click" Content="-" automation:AutomationProperties.AutomationId="Shell.MinimizeButton" automation:AutomationProperties.Name="تصغير" />
                </StackPanel>

                <Border Grid.Column="1"
                        Width="450"
                        Height="28"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="14,0"
                        Background="White"
                        BorderBrush="#D8E1EE"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid FlowDirection="RightToLeft" Margin="10,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="ShellGlobalSearchBox"
                                 Grid.Column="0"
                                 Style="{StaticResource SearchTextBox}"
                                 Background="Transparent"
                                 Text="{Binding GlobalSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="ShellGlobalSearchBox_KeyDown"
                                 ToolTip="بحث عام على مستوى البرنامج. أمثلة: الطلبات: تمديد ، المتابعات: منتهي ، الإعدادات"
                                 automation:AutomationProperties.AutomationId="Shell.GlobalSearchBox"
                                 automation:AutomationProperties.Name="البحث الشامل" />
                        <TextBlock Grid.Column="0"
                                   Text="ابحث عامًّا أو اكتب: المتابعات: منتهي"
                                   FontSize="11"
                                   Foreground="#94A3B8"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding Text, ElementName=ShellGlobalSearchBox, Converter={StaticResource EmptyStringToVisibilityConverter}}" />
                        <Button Grid.Column="1"
                                Width="24"
                                Height="24"
                                Command="{Binding ExecuteGlobalSearchCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="تنفيذ البحث الشامل"
                                automation:AutomationProperties.AutomationId="Shell.GlobalSearchButton"
                                automation:AutomationProperties.Name="تنفيذ البحث الشامل">
                            <Viewbox Width="14" Height="14">
                                <Path Data="{StaticResource Icon.Search}" Stroke="#64748B" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                        </Button>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <TextBlock Text="إدارة الضمانات البنكية"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <Image Source="pack://application:,,,/Assets/KFSHRC/kfshrc-favicon-mono.png"
                           Width="20"
                           Height="20"
                           Margin="9,0,0,0" />
                    <Border Width="1" Height="22" Background="#24466F" Margin="13,0,10,0" />
                    <TextBlock Text="☰"
                               Foreground="White"
                               FontSize="17"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" FlowDirection="LeftToRight">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="310" />
                <ColumnDefinition Width="57" />
            </Grid.ColumnDefinitions>

            <local:GuaranteesDashboardView Grid.Column="0"
                                           automation:AutomationProperties.AutomationId="Shell.GuaranteesWorkspaceView" />

            <local:GuaranteeDetailPanel Grid.Column="1"
                                        automation:AutomationProperties.AutomationId="Shell.GuaranteeDetailPanel" />

            <ContentControl Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Content="{Binding ActiveWorkspaceContent}"
                            Visibility="{Binding ActiveWorkspaceContent, Converter={StaticResource NullToCollapsedConverter}}"
                            Panel.ZIndex="30"
                            automation:AutomationProperties.AutomationId="Shell.ActiveWorkspaceHost" />

            <Border Grid.Column="2" Background="{StaticResource Brush.Sidebar}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- عناصر التنقل -->
                    <StackPanel Grid.Row="0" Margin="0,10,0,0" HorizontalAlignment="Center">
                        <!-- اليوم -->
                        <Button Command="{Binding ShowDashboardCommand}" automation:AutomationProperties.AutomationId="Shell.Sidebar.Dashboard" automation:AutomationProperties.Name="اليوم">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentWorkspaceKey}" Value="{x:Static local:ShellWorkspaceKeys.Dashboard}">
                                            <Setter Property="Background" Value="#1D5ED8" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel>
                                <Viewbox Width="20" Height="20" Margin="0,0,0,2">
                                    <Path Data="{StaticResource Icon.Dashboard}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Viewbox>
                                <TextBlock Text="اليوم" Style="{StaticResource NavLabelText}" />
                            </StackPanel>
                        </Button>

                        <!-- الطلبات -->
                        <Button
                                Margin="0,2,0,0"
                                Command="{Binding ShowRequestsCommand}"
                                automation:AutomationProperties.AutomationId="Shell.Sidebar.Requests"
                                automation:AutomationProperties.Name="الطلبات">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentWorkspaceKey}" Value="{x:Static local:ShellWorkspaceKeys.Requests}">
                                            <Setter Property="Background" Value="#1D5ED8" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel>
                                <Viewbox Width="20" Height="20" Margin="0,0,0,2">
                                    <Path Data="{StaticResource Icon.Requests}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Viewbox>
                                <TextBlock Text="الطلبات" Style="{StaticResource NavLabelText}" />
                            </StackPanel>
                        </Button>

                        <!-- الضمانات -->
                        <Button
                                Margin="0,2,0,0"
                                Command="{Binding ShowGuaranteesCommand}"
                                automation:AutomationProperties.AutomationId="Shell.Sidebar.Guarantees"
                                automation:AutomationProperties.Name="الضمانات">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentWorkspaceKey}" Value="{x:Static local:ShellWorkspaceKeys.Guarantees}">
                                            <Setter Property="Background" Value="#1D5ED8" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel>
                                <Viewbox Width="20" Height="20" Margin="0,0,0,2">
                                    <Path Data="{StaticResource Icon.Guarantees}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Viewbox>
                                <TextBlock Text="الضمانات" Style="{StaticResource NavLabelText}" />
                            </StackPanel>
                        </Button>

                        <Border Style="{StaticResource NavSectionDivider}" />

                        <!-- التحليلات -->
                        <Button
                                Margin="0,2,0,0"
                                Command="{Binding ShowReportsCommand}"
                                automation:AutomationProperties.AutomationId="Shell.Sidebar.Reports"
                                automation:AutomationProperties.Name="التحليلات">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentWorkspaceKey}" Value="{x:Static local:ShellWorkspaceKeys.Reports}">
                                            <Setter Property="Background" Value="#1D5ED8" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel>
                                <Viewbox Width="20" Height="20" Margin="0,0,0,2">
                                    <Path Data="{StaticResource Icon.Reports}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Viewbox>
                                <TextBlock Text="التحليلات" Style="{StaticResource NavLabelText}" />
                            </StackPanel>
                        </Button>

                        <Border Style="{StaticResource NavSectionDivider}" />

                        <!-- الإعدادات -->
                        <Button
                                Margin="0,2,0,0"
                                Command="{Binding ShowSettingsCommand}"
                                automation:AutomationProperties.AutomationId="Shell.Sidebar.Settings"
                                automation:AutomationProperties.Name="الإعدادات">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentWorkspaceKey}" Value="{x:Static local:ShellWorkspaceKeys.Settings}">
                                            <Setter Property="Background" Value="#1D5ED8" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel>
                                <Viewbox Width="20" Height="20" Margin="0,0,0,2">
                                    <Path Data="{StaticResource Icon.Settings}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Viewbox>
                                <TextBlock Text="الإعدادات" Style="{StaticResource NavLabelText}" />
                            </StackPanel>
                        </Button>

                    </StackPanel>

                    <!-- تسجيل الخروج -->
                    <Button Grid.Row="1"
                            Style="{StaticResource NavButton}"
                            Margin="0,0,0,14"
                            Command="{Binding ExitCommand}">
                        <StackPanel>
                             <Viewbox Width="20" Height="20" Margin="0,0,0,2">
                                 <Path Data="{StaticResource Icon.Logout}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                             </Viewbox>
                             <TextBlock Text="خروج" Style="{StaticResource NavLabelText}" />
                        </StackPanel>
                    </Button>

                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#04193F"
                BorderBrush="#24466F"
                BorderThickness="0,1,0,0"
                FlowDirection="LeftToRight"
                Padding="10,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="ShellStatusPrimaryBlock"
                               Text="{Binding ShellStatusPrimaryText}"
                               Foreground="{Binding ShellStatusPrimaryBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               automation:AutomationProperties.AutomationId="Shell.Status.Primary"
                               automation:AutomationProperties.HelpText="{Binding ShellStatusPrimaryText}"
                               automation:AutomationProperties.ItemStatus="{Binding ShellStatusPrimaryText}" />
                    <Border Width="1" Height="12" Background="#2A4B76" Margin="10,0" />
                    <TextBlock x:Name="ShellStatusSecondaryBlock"
                               Text="{Binding ShellStatusSecondaryText}"
                               Foreground="#94A3C8"
                               FontSize="11"
                               VerticalAlignment="Center"
                               automation:AutomationProperties.AutomationId="Shell.Status.Secondary"
                               automation:AutomationProperties.HelpText="{Binding ShellStatusSecondaryText}"
                               automation:AutomationProperties.ItemStatus="{Binding ShellStatusSecondaryText}" />
                    <Border Width="1" Height="12" Background="#2A4B76" Margin="10,0" />
                    <TextBlock Text="{Binding CurrentWorkspaceDisplayTitle}"
                               Foreground="#94A3C8"
                               FontSize="11"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="{x:Static local:AppReleaseInfo.VersionTag}"
                                Foreground="#94A3C8"
                                FontSize="11"
                                VerticalAlignment="Center" />
                    <Border Width="1" Height="12" Background="#2A4B76" Margin="10,0" />
                    <TextBlock Text="{x:Static local:AppReleaseInfo.RuntimeTag}"
                                Foreground="#94A3C8"
                                FontSize="11"
                                VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="WindowFocusFrame"
                Grid.RowSpan="3"
                BorderThickness="1"
                IsHitTestVisible="False"
                Panel.ZIndex="1000"
                SnapsToDevicePixels="True">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="#2A3F63" />
                    <Setter Property="Opacity" Value="0.75" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                <Condition Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Normal" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="BorderBrush" Value="#0A84FF" />
                            <Setter Property="Opacity" Value="1" />
                        </MultiDataTrigger>

                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False" />
                                <Condition Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Normal" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="BorderBrush" Value="#5B6980" />
                            <Setter Property="Opacity" Value="0.7" />
                        </MultiDataTrigger>

                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                            <Setter Property="BorderBrush" Value="#24466F" />
                            <Setter Property="Opacity" Value="0.55" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>
    </Grid>
</Window>
