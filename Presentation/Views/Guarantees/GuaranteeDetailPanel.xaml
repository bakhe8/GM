<UserControl x:Class="GuaranteeManager.GuaranteeDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Root"
             automation:AutomationProperties.Name="ملف الضمان">

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#E3E9F2"
                    BorderThickness="1,0,0,0"
                    FlowDirection="RightToLeft">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer x:Name="RootScrollViewer"
                                  Grid.Row="0"
                                  VerticalScrollBarVisibility="Hidden"
                                  automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.ScrollViewer"
                                  automation:AutomationProperties.Name="تمرير ملف الضمان">
                        <StackPanel Margin="16,14">
                            <Grid Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                    <TextBlock Text="{Binding SelectedGuarantee.GuaranteeNo}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" />
                                    <Viewbox Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Path Data="{StaticResource Icon.Badge}" Stroke="{StaticResource Brush.Muted}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Viewbox>
                                </StackPanel>
                                <Button Width="28"
                                        Height="28"
                                        Content="×"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#64748B"
                                        Click="ClosePanelButton_Click"
                                        ToolTip="إغلاق الملف المستقل إن كان مفتوحًا في نافذة منفصلة"
                                        automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.CloseDetachedFileButton"
                                        automation:AutomationProperties.Name="إغلاق الملف المستقل" />
                            </Grid>
                            <Border Style="{StaticResource StatusPill}"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,12"
                                    Background="{Binding SelectedGuarantee.WorkBackground}"
                                    BorderBrush="{Binding SelectedGuarantee.WorkBorder}">
                                <TextBlock Text="{Binding SelectedGuarantee.WorkStatus}" Foreground="{Binding SelectedGuarantee.WorkBrush}" FontSize="10" FontWeight="SemiBold" />
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedGuarantee.Beneficiary}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" />
                                <Viewbox Width="14" Height="14" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <Path Data="{StaticResource Icon.User}" Stroke="{StaticResource Brush.Muted}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Viewbox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding SelectedGuarantee.Bank}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center" />
                                <Image Source="{Binding SelectedGuarantee.BankLogo}" Width="17" Height="17" Margin="7,0,0,0" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedGuarantee.Amount}" FontSize="34" FontWeight="Bold" Foreground="#0F172A" Margin="0,12,0,0" />
                            <TextBlock Text="{Binding SelectedGuarantee.AmountDescription}" FontSize="11.5" Foreground="{StaticResource Brush.Muted}" />
                            <Border Height="1" Background="#EDF2F7" Margin="0,13,0,12" />

                            <StackPanel x:Name="ExecutiveSummaryAnchor"
                                        automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Section.ExecutiveSummary"
                                        automation:AutomationProperties.Name="قسم الملخص التنفيذي">
                                <Border Style="{StaticResource Card}"
                                        Padding="12"
                                        Margin="0,0,0,14"
                                        Effect="{x:Null}"
                                        automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Section.ActionSummary"
                                        automation:AutomationProperties.Name="قسم بداية القرار">
                                    <StackPanel>
                                        <TextBlock Text="ابدأ من هنا" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" Margin="0,0,0,8" />
                                        <Border Height="1" Background="{StaticResource Brush.Border}" Margin="0,0,0,10" />
                                        <TextBlock Text="{Binding SelectedGuarantee.ActionSummaryTitle}"
                                                   FontSize="11.2"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource Brush.Text}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedGuarantee.ActionSummaryDetail}"
                                                   FontSize="10.4"
                                                   Foreground="{StaticResource Brush.Muted}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0" />
                                        <Button Command="{Binding FocusSuggestedGuaranteeActionCommand}"
                                                Margin="0,10,0,0"
                                                ToolTip="{Binding SelectedGuarantee.SuggestedFocusLabel}"
                                                automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.ActionSummary.FocusSuggested"
                                                automation:AutomationProperties.Name="فتح القسم المقترح">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource PlainLinkButton}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedGuarantee.HasSuggestedFocus}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="{Binding SelectedGuarantee.SuggestedFocusLabel}" FontSize="10.3" Foreground="{StaticResource Brush.Blue}" />
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="خريطة الملف" FontSize="10.8" FontWeight="Bold" Foreground="{StaticResource Brush.Muted}" />
                                    <TextBlock Text="بعد تثبيت محور القرار، انتقل مباشرة إلى القسم الذي يخدم التنفيذ أو المراجعة." FontSize="10.1" Foreground="{StaticResource Brush.Muted}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                </StackPanel>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Style="{StaticResource Card}"
                                            Padding="10"
                                            Effect="{x:Null}">
                                        <StackPanel>
                                            <TextBlock Text="القرار والتنفيذ" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" Margin="0,0,0,6" />
                                            <WrapPanel FlowDirection="RightToLeft">
                                                <Button Style="{StaticResource PlainLinkButton}"
                                                        Command="{Binding FocusActionsSectionCommand}"
                                                        Margin="0,0,8,6"
                                                        automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Navigator.Actions"
                                                        automation:AutomationProperties.Name="الانتقال إلى الإجراءات">
                                                    <TextBlock Text="الإجراءات" FontSize="10.3" Foreground="{StaticResource Brush.Blue}" />
                                                </Button>
                                                <Button Style="{StaticResource PlainLinkButton}"
                                                        Command="{Binding FocusRequestsSectionCommand}"
                                                        Margin="0,0,8,6"
                                                        automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Navigator.Requests"
                                                        automation:AutomationProperties.Name="الانتقال إلى الطلبات">
                                                    <TextBlock Text="الطلبات" FontSize="10.3" Foreground="{StaticResource Brush.Blue}" />
                                                </Button>
                                                <Button Style="{StaticResource PlainLinkButton}"
                                                        Command="{Binding FocusExecutiveSummaryCommand}"
                                                        Margin="0,0,0,6"
                                                        automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Navigator.ExecutiveSummary"
                                                        automation:AutomationProperties.Name="الانتقال إلى الملخص">
                                                    <TextBlock Text="الملخص" FontSize="10.3" Foreground="{StaticResource Brush.Blue}" />
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Style="{StaticResource Card}"
                                            Padding="10"
                                            Effect="{x:Null}">
                                        <StackPanel>
                                            <TextBlock Text="المراجعة والأثر" FontSize="10.5" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" Margin="0,0,0,6" />
                                            <WrapPanel FlowDirection="RightToLeft">
                                                <Button Style="{StaticResource PlainLinkButton}"
                                                        Command="{Binding FocusTimelineSectionCommand}"
                                                        Margin="0,0,8,6"
                                                        automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Navigator.Timeline"
                                                        automation:AutomationProperties.Name="الانتقال إلى الخط الزمني">
                                                    <TextBlock Text="الخط الزمني" FontSize="10.3" Foreground="{StaticResource Brush.Blue}" />
                                                </Button>
                                                <Button Style="{StaticResource PlainLinkButton}"
                                                        Command="{Binding FocusAttachmentsSectionCommand}"
                                                        Margin="0,0,8,6"
                                                        automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Navigator.Attachments"
                                                        automation:AutomationProperties.Name="الانتقال إلى المرفقات">
                                                    <TextBlock Text="المرفقات" FontSize="10.3" Foreground="{StaticResource Brush.Blue}" />
                                                </Button>
                                                <Button Style="{StaticResource PlainLinkButton}"
                                                        Command="{Binding FocusOutputsSectionCommand}"
                                                        Margin="0,0,8,6"
                                                        automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Navigator.Outputs"
                                                        automation:AutomationProperties.Name="الانتقال إلى المخرجات">
                                                    <TextBlock Text="المخرجات" FontSize="10.3" Foreground="{StaticResource Brush.Blue}" />
                                                </Button>
                                                <Button Style="{StaticResource PlainLinkButton}"
                                                        Command="{Binding OpenGuaranteeFileCommand}"
                                                        CommandParameter="{Binding SelectedGuarantee}"
                                                        Margin="0,0,0,6"
                                                        automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Navigator.OpenFile"
                                                        automation:AutomationProperties.Name="فتح ملف الضمان">
                                                    <TextBlock Text="فتح الملف" FontSize="10.3" Foreground="{StaticResource Brush.Blue}" />
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>

                            <Grid FlowDirection="RightToLeft"
                                  automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.ReferenceFacts"
                                  automation:AutomationProperties.Name="بيانات الضمان المرجعية">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="26" />
                                    <RowDefinition Height="26" />
                                    <RowDefinition Height="26" />
                                    <RowDefinition Height="26" />
                                </Grid.RowDefinitions>
                                <!-- نوع الضمان -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Viewbox Width="12" Height="12" Margin="5,0,0,0" VerticalAlignment="Center">
                                        <Path Data="{StaticResource Icon.Guarantees}" Stroke="{StaticResource Brush.Muted}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Viewbox>
                                    <TextBlock Text="نوع الضمان" FontSize="10" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedGuarantee.GuaranteeType}" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                <!-- رقم العقد -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Viewbox Width="12" Height="12" Margin="5,0,0,0" VerticalAlignment="Center">
                                        <Path Data="{StaticResource Icon.Document}" Stroke="{StaticResource Brush.Muted}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Viewbox>
                                    <TextBlock Text="{Binding SelectedGuarantee.ReferenceFieldLabel}" FontSize="10" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedGuarantee.ReferenceNumber}" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center" FlowDirection="LeftToRight" HorizontalAlignment="Right" />
                                <!-- تاريخ الإصدار -->
                                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Viewbox Width="12" Height="12" Margin="5,0,0,0" VerticalAlignment="Center">
                                        <Path Data="{StaticResource Icon.Calendar}" Stroke="{StaticResource Brush.Muted}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Viewbox>
                                    <TextBlock Text="تاريخ الإصدار" FontSize="10" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedGuarantee.IssueDate}" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center" FlowDirection="LeftToRight" HorizontalAlignment="Right" />
                                <!-- تاريخ الانتهاء -->
                                <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Viewbox Width="12" Height="12" Margin="5,0,0,0" VerticalAlignment="Center">
                                        <Path Data="{StaticResource Icon.History}" Stroke="{StaticResource Brush.Muted}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Viewbox>
                                    <TextBlock Text="تاريخ الانتهاء" FontSize="10" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding SelectedGuarantee.ExpiryDate}" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center" FlowDirection="LeftToRight" />
                                    <TextBlock Text="{Binding SelectedGuarantee.ExpiryRemainingLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{Binding SelectedGuarantee.TimeBrush}" />
                                </StackPanel>
                            </Grid>

                            <Border Style="{StaticResource Card}"
                                    Padding="12"
                                    Margin="0,14,0,0"
                                    Effect="{x:Null}"
                                    automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Section.OperationalInquiry"
                                    automation:AutomationProperties.Name="قسم الاستعلامات التشغيلية">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft" Margin="0,0,0,8">
                                        <TextBlock Text="استعلامات تشغيلية" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" VerticalAlignment="Center" />
                                        <Viewbox Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center">
                                            <Path Data="{StaticResource Icon.Search}" Stroke="{StaticResource Brush.Text}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                        </Viewbox>
                                    </StackPanel>
                                    <Border Height="1" Background="{StaticResource Brush.Border}" Margin="0,0,0,10" />
                                    <TextBlock Text="اختر سؤالاً مباشرًا عن هذا الضمان أو عن البنك والمورد المرتبطين به، وسيفتح الجواب مدعومًا بالأدلة."
                                               FontSize="10.6"
                                               Foreground="{StaticResource Brush.Muted}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10" />
                                    <ComboBox Style="{StaticResource FilterComboBox}"
                                              ItemsSource="{Binding OperationalInquiryOptions}"
                                              SelectedItem="{Binding SelectedOperationalInquiryOption, Mode=TwoWay}"
                                              DisplayMemberPath="Display"
                                              MinWidth="240"
                                              Margin="0,0,0,8"
                                              automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.OperationalInquiry.Options"
                                              automation:AutomationProperties.Name="اختيار الاستعلام التشغيلي" />
                                    <TextBlock Text="{Binding SelectedOperationalInquiryDescription}"
                                               FontSize="10.4"
                                               Foreground="{StaticResource Brush.Muted}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10" />
                                    <Button Style="{StaticResource BaseButton}"
                                            Height="32"
                                            Content="اعرض الجواب"
                                            Command="{Binding RunSelectedInquiryCommand}"
                                            automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.OperationalInquiry.Run"
                                            automation:AutomationProperties.Name="عرض الجواب التشغيلي" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}"
                                    Padding="12"
                                    Margin="0,14,0,0"
                                    Effect="{x:Null}"
                                    automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Section.LatestInquiry"
                                    automation:AutomationProperties.Name="قسم آخر جواب تشغيلي">
                                <StackPanel>
                                    <TextBlock Text="آخر جواب تشغيلي" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" Margin="0,0,0,8" />
                                    <Border Height="1" Background="{StaticResource Brush.Border}" Margin="0,0,0,10" />
                                    <StackPanel Visibility="Collapsed">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasLatestInquiryResult}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="{Binding LatestInquiryResult.Title}"
                                                   FontSize="11.2"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource Brush.Text}" />
                                        <TextBlock Text="{Binding LatestInquiryResult.Answer}"
                                                   FontSize="10.5"
                                                   Foreground="{StaticResource Brush.Text}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,7,0,0" />
                                        <TextBlock Text="{Binding LatestInquiryResult.Explanation}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource Brush.Muted}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,7,0,0" />
                                        <ItemsControl ItemsSource="{Binding LatestInquiryResult.Facts}" Margin="0,10,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,4" FlowDirection="RightToLeft">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="112" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}"
                                                                   FontSize="9.8"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource Brush.Muted}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Value}"
                                                                   FontSize="9.8"
                                                                   Foreground="{StaticResource Brush.Text}"
                                                                   TextWrapping="Wrap"
                                                                   HorizontalAlignment="Right" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="{Binding LatestInquiryResult.EventDateLabel}"
                                                   FontSize="9.6"
                                                   Foreground="{StaticResource Brush.Muted}"
                                                   FlowDirection="LeftToRight"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,6,0,0" />
                                        <WrapPanel Margin="0,10,0,0" FlowDirection="RightToLeft">
                                            <Button Command="{Binding FocusLatestInquirySectionCommand}"
                                                    Margin="0,0,10,6"
                                                    automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.LatestInquiry.FocusSuggested"
                                                    automation:AutomationProperties.Name="فتح القسم المقترح من آخر جواب">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource PlainLinkButton}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding LatestInquirySuggestedSectionLabel}" Value="لا يوجد قسم مقترح">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <Trigger Property="IsEnabled" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="{Binding LatestInquirySuggestedSectionLabel}" FontSize="10.3" Foreground="{StaticResource Brush.Blue}" />
                                            </Button>
                                            <Button Style="{StaticResource PlainLinkButton}"
                                                    Command="{Binding OpenLatestInquiryDialogCommand}"
                                                    Margin="0,0,10,6"
                                                    automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.LatestInquiry.OpenDialog"
                                                    automation:AutomationProperties.Name="فتح آخر جواب تشغيلي">
                                                <TextBlock Text="فتح الجواب" FontSize="10.3" Foreground="{StaticResource Brush.Blue}" />
                                            </Button>
                                            <Button Style="{StaticResource PlainLinkButton}"
                                                    Command="{Binding OpenLatestInquiryHistoryCommand}"
                                                    Margin="0,0,10,6"
                                                    automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.LatestInquiry.OpenHistory"
                                                    automation:AutomationProperties.Name="فتح السجل من آخر جواب">
                                                <TextBlock Text="فتح السجل" FontSize="10.3" Foreground="{StaticResource Brush.Blue}" />
                                            </Button>
                                            <Button Style="{StaticResource PlainLinkButton}"
                                                    Command="{Binding OpenLatestInquiryLetterCommand}"
                                                    Margin="0,0,10,6"
                                                    automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.LatestInquiry.OpenLetter"
                                                    automation:AutomationProperties.Name="فتح خطاب الطلب من آخر جواب">
                                                <TextBlock Text="خطاب الطلب" FontSize="10.3" Foreground="{StaticResource Brush.Blue}" />
                                            </Button>
                                            <Button Style="{StaticResource PlainLinkButton}"
                                                    Command="{Binding OpenLatestInquiryResponseCommand}"
                                                    Margin="0,0,0,6"
                                                    automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.LatestInquiry.OpenResponse"
                                                    automation:AutomationProperties.Name="فتح رد البنك من آخر جواب">
                                                <TextBlock Text="رد البنك" FontSize="10.3" Foreground="{StaticResource Brush.Blue}" />
                                            </Button>
                                        </WrapPanel>
                                    </StackPanel>
                                    <TextBlock Text="لم يتم تشغيل استعلام بعد لهذا الضمان."
                                               FontSize="10.4"
                                               Foreground="{StaticResource Brush.Muted}"
                                               Visibility="Collapsed">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasLatestInquiryResult}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border x:Name="RequestsAnchor"
                                    Style="{StaticResource Card}"
                                    Padding="12"
                                    Margin="0,14,0,0"
                                    Effect="{x:Null}"
                                    automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Section.Requests"
                                    automation:AutomationProperties.Name="قسم الطلبات المرتبطة">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="الطلبات التي تقود التنفيذ" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" VerticalAlignment="Center" />
                                        <Border Grid.Column="1"
                                                CornerRadius="9"
                                                Padding="7,2"
                                                Background="#F8FAFC"
                                                BorderBrush="{StaticResource Brush.Border}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding GuaranteeRequestsContextLabel}"
                                                       FontSize="9"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brush.Muted}" />
                                        </Border>
                                    </Grid>
                                    <Border Height="1" Background="{StaticResource Brush.Border}" Margin="0,0,0,10" />
                                    <TextBlock Text="{Binding GuaranteeRequestsSummaryText}"
                                               FontSize="10.4"
                                               Foreground="{StaticResource Brush.Muted}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10" />
                                    <ItemsControl ItemsSource="{Binding GuaranteeRequestsPreview}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource Brush.Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Background="White"
