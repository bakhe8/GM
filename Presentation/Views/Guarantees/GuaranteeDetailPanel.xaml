<UserControl x:Class="GuaranteeManager.GuaranteeDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Root"
             automation:AutomationProperties.Name="تفاصيل الضمان">
    <Border Grid.Column="1"
            Background="White"
            BorderBrush="#E3E9F2"
            BorderThickness="1,0,0,0"
            FlowDirection="RightToLeft">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="RootScrollViewer"
                          Grid.Row="0"
                          VerticalScrollBarVisibility="Hidden"
                          automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.ScrollViewer"
                          automation:AutomationProperties.Name="تمرير تفاصيل الضمان">
                <StackPanel Margin="16,14">
                    <Grid Margin="0,0,0,12" FlowDirection="LeftToRight">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Style="{StaticResource StatusPill}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="{Binding SelectedGuarantee.WorkBackground}"
                                BorderBrush="{Binding SelectedGuarantee.WorkBorder}">
                            <TextBlock Text="{Binding SelectedGuarantee.WorkStatus}" Foreground="{Binding SelectedGuarantee.WorkBrush}" FontSize="10" FontWeight="SemiBold" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    FlowDirection="RightToLeft"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedGuarantee.GuaranteeNo}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" />
                            <Border Width="3" />
                            <Button Style="{StaticResource IconOnlyButton}"
                                    Margin="0"
                                    ToolTip="نسخ رقم الضمان"
                                    Command="{Binding CopyGuaranteeNoCommand}"
                                    CommandParameter="{Binding SelectedGuarantee}"
                                    automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Header.CopyGuaranteeNo"
                                    automation:AutomationProperties.Name="نسخ رقم الضمان">
                                <Viewbox Width="12" Height="12">
                                    <Path Data="{StaticResource Icon.Copy}" Stroke="#64748B" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                        <Viewbox Width="14" Height="14" VerticalAlignment="Center">
                            <Path Data="{StaticResource Icon.User}" Stroke="{StaticResource Brush.Muted}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Viewbox>
                        <TextBlock Text="{Binding SelectedGuarantee.Beneficiary}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" Margin="8,0,0,0" />
                        <Border Width="3" />
                        <Button Style="{StaticResource IconOnlyButton}"
                                Margin="0"
                                ToolTip="نسخ اسم المستفيد"
                                Command="{Binding CopyGuaranteeSupplierCommand}"
                                CommandParameter="{Binding SelectedGuarantee}"
                                automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Header.CopyBeneficiary"
                                automation:AutomationProperties.Name="نسخ اسم المستفيد">
                            <Viewbox Width="12" Height="12">
                                <Path Data="{StaticResource Icon.Copy}" Stroke="#64748B" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft" Margin="0,5,0,0" HorizontalAlignment="Right">
                        <Image Source="{Binding SelectedGuarantee.BankLogo}" Width="17" Height="17" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Text="{Binding SelectedGuarantee.Bank}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center" Margin="7,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="{Binding SelectedGuarantee.Amount}" FontSize="34" FontWeight="Bold" Foreground="#0F172A" Margin="0,12,0,0" HorizontalAlignment="Left" TextAlignment="Right" />
                    <TextBlock Text="{Binding SelectedGuarantee.AmountDescription}" FontSize="11.5" Foreground="{StaticResource Brush.Muted}" HorizontalAlignment="Left" TextAlignment="Right" />
                    <Border Height="1" Background="#EDF2F7" Margin="0,13,0,12" />

                    <Grid FlowDirection="RightToLeft"
                          automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.ReferenceFacts"
                          automation:AutomationProperties.Name="بيانات الضمان المرجعية">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="118" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="28" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28" />
                            <RowDefinition Height="28" />
                            <RowDefinition Height="28" />
                            <RowDefinition Height="28" />
                            <RowDefinition Height="28" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                                <Path Data="{StaticResource Icon.Guarantees}" Stroke="{StaticResource Brush.Muted}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                            <Border Width="7" />
                            <TextBlock Text="نوع الضمان" FontSize="10" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding SelectedGuarantee.GuaranteeType}" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />
                        <Button Grid.Row="0"
                                Grid.Column="3"
                                Padding="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Style="{StaticResource IconOnlyButton}"
                                ToolTip="نسخ نوع الضمان"
                                Command="{Binding CopyGuaranteeTypeCommand}"
                                CommandParameter="{Binding SelectedGuarantee}"
                                automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.ReferenceFacts.CopyGuaranteeType"
                                automation:AutomationProperties.Name="نسخ نوع الضمان">
                            <Viewbox Width="12" Height="12">
                                <Path Data="{StaticResource Icon.Copy}" Stroke="#64748B" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                        </Button>

                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                                <Path Data="{StaticResource Icon.Document}" Stroke="{StaticResource Brush.Muted}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                            <Border Width="7" />
                            <TextBlock Text="{Binding SelectedGuarantee.ReferenceFieldLabel}" FontSize="10" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding SelectedGuarantee.ReferenceNumber}" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center" FlowDirection="LeftToRight" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />
                        <Button Grid.Row="1"
                                Grid.Column="3"
                                Padding="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Style="{StaticResource IconOnlyButton}"
                                ToolTip="نسخ رقم المرجع"
                                Command="{Binding CopyGuaranteeReferenceNumberCommand}"
                                CommandParameter="{Binding SelectedGuarantee}"
                                automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.ReferenceFacts.CopyReferenceNumber"
                                automation:AutomationProperties.Name="نسخ رقم المرجع">
                            <Viewbox Width="12" Height="12">
                                <Path Data="{StaticResource Icon.Copy}" Stroke="#64748B" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                        </Button>

                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                                <Path Data="{StaticResource Icon.History}" Stroke="{StaticResource Brush.Muted}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                            <Border Width="7" />
                            <TextBlock Text="الإصدار" FontSize="10" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding SelectedGuarantee.VersionLabel}" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center" FlowDirection="LeftToRight" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />

                        <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                                <Path Data="{StaticResource Icon.Calendar}" Stroke="{StaticResource Brush.Muted}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                            <Border Width="7" />
                            <TextBlock Text="تاريخ الإصدار" FontSize="10" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding SelectedGuarantee.IssueDate}" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center" FlowDirection="LeftToRight" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />
                        <Button Grid.Row="3"
                                Grid.Column="3"
                                Padding="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Style="{StaticResource IconOnlyButton}"
                                ToolTip="نسخ تاريخ الإصدار"
                                Command="{Binding CopyGuaranteeIssueDateCommand}"
                                CommandParameter="{Binding SelectedGuarantee}"
                                automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.ReferenceFacts.CopyIssueDate"
                                automation:AutomationProperties.Name="نسخ تاريخ الإصدار">
                            <Viewbox Width="12" Height="12">
                                <Path Data="{StaticResource Icon.Copy}" Stroke="#64748B" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                        </Button>

                        <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="12" Height="12" VerticalAlignment="Center">
                                <Path Data="{StaticResource Icon.History}" Stroke="{StaticResource Brush.Muted}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                            <Border Width="7" />
                            <TextBlock Text="تاريخ الانتهاء" FontSize="10" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding SelectedGuarantee.ExpiryDate}" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center" FlowDirection="LeftToRight" />
                            <Border Width="7" />
                            <TextBlock Text="{Binding SelectedGuarantee.ExpiryRemainingLabel}" FontSize="10" FontWeight="SemiBold" Foreground="{Binding SelectedGuarantee.TimeBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button Grid.Row="4"
                                Grid.Column="3"
                                Padding="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Style="{StaticResource IconOnlyButton}"
                                ToolTip="نسخ تاريخ الانتهاء"
                                Command="{Binding CopyGuaranteeExpiryDateCommand}"
                                CommandParameter="{Binding SelectedGuarantee}"
                                automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.ReferenceFacts.CopyExpiryDate"
                                automation:AutomationProperties.Name="نسخ تاريخ الانتهاء">
                            <Viewbox Width="12" Height="12">
                                <Path Data="{StaticResource Icon.Copy}" Stroke="#64748B" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                        </Button>
                    </Grid>

                    <Border x:Name="TimelineAnchor"
                            Style="{StaticResource Card}"
                            Focusable="True"
                            Padding="12"
                            Margin="0,14,0,0"
                            Effect="{x:Null}"
                            automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Section.Timeline"
                            automation:AutomationProperties.Name="قسم الخط الزمني">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ما الذي حدث ومتى؟" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" VerticalAlignment="Center" />
                                <Border Grid.Column="1"
                                        CornerRadius="9"
                                        Padding="7,2"
                                        Background="#F8FAFC"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding TimelineStationsLabel}"
                                               FontSize="9"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Muted}" />
                                </Border>
                            </Grid>
                            <Border Height="1" Background="{StaticResource Brush.Border}" Margin="0,0,0,12" />
                            <TextBlock Text="{Binding TimelineSummaryText}"
                                       FontSize="10.4"
                                       Foreground="{StaticResource Brush.Muted}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10" />
                            <ItemsControl ItemsSource="{Binding Timeline}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,12" FlowDirection="RightToLeft">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="76" />
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Top"
                                                        Margin="0,3,0,0"
                                                        FlowDirection="LeftToRight">
                                                <TextBlock Text="{Binding Date}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource Brush.Muted}" />
                                                <TextBlock Text="{Binding Time}"
                                                           FontSize="9"
                                                           FontWeight="SemiBold"
                                                           Foreground="#94A3B8"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>
                                            <Grid Grid.Column="1" HorizontalAlignment="Center">
                                                <Rectangle Width="1.5" Fill="#E2E8F0" HorizontalAlignment="Center" Margin="0,10,0,-12" />
                                                <Grid VerticalAlignment="Top" Margin="0,2,0,0">
                                                    <Ellipse x:Name="Dot" Width="10" Height="10" Fill="{Binding Brush}" />
                                                    <Viewbox x:Name="CheckIcon" Width="6" Height="6" Visibility="Collapsed">
                                                        <Path Data="{StaticResource Icon.Check}" Stroke="White" StrokeThickness="4" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    </Viewbox>
                                                    <Ellipse x:Name="DotHollow" Width="10" Height="10" Stroke="{Binding Brush}" StrokeThickness="1.5" Fill="White" Visibility="Collapsed" />
                                                </Grid>
                                            </Grid>
                                            <StackPanel Grid.Column="2" FlowDirection="RightToLeft">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Title}" FontSize="11.2" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" />
                                                    <Border CornerRadius="9" Padding="7,2" Margin="6,0,0,0"
                                                            Background="{Binding StatusBackground}" BorderBrush="{Binding StatusBorder}" BorderThickness="1">
                                                        <TextBlock Text="{Binding Status}" FontSize="9" FontWeight="SemiBold" Foreground="{Binding Brush}" />
                                                    </Border>
                                                    <Button Style="{StaticResource IconOnlyButton}"
                                                            Width="{Binding EvidenceActionWidth}"
                                                            Height="{Binding EvidenceActionHeight}"
                                                            MinWidth="{Binding EvidenceActionWidth}"
                                                            Margin="4,0,0,0"
                                                            ToolTip="{Binding EvidenceActionHint}"
                                                            Command="{Binding DataContext.OpenTimelineEvidenceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding HasEvidenceAction, Converter={StaticResource TrueToVisibleCollapsedConverter}}"
                                                            automation:AutomationProperties.AutomationId="{Binding EvidenceActionAutomationId}"
                                                            automation:AutomationProperties.Name="{Binding EvidenceActionLabel}">
                                                        <Grid>
                                                            <Border Width="18"
                                                                    Height="18"
                                                                    CornerRadius="9"
                                                                    Background="#F8FAFC"
                                                                    BorderBrush="#D8E1EE"
                                                                    BorderThickness="1"
                                                                    Visibility="{Binding IsOpenEvidenceAction, Converter={StaticResource TrueToVisibleCollapsedConverter}}">
                                                                <Viewbox Width="10.5" Height="10.5">
                                                                    <Path Data="{StaticResource Icon.Paperclip}" Stroke="#2563EB" StrokeThickness="2.1" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                                </Viewbox>
                                                            </Border>
                                                            <Border Width="42"
                                                                    Height="20"
                                                                    CornerRadius="9"
                                                                    Background="#EFF6FF"
                                                                    BorderBrush="#BFDBFE"
                                                                    BorderThickness="1"
                                                                    Visibility="{Binding IsAttachEvidenceAction, Converter={StaticResource TrueToVisibleCollapsedConverter}}">
                                                                <TextBlock Text="إرفاق"
                                                                           FontSize="8.7"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#2563EB"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" />
                                                            </Border>
                                                        </Grid>
                                                    </Button>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Detail}" FontSize="10" Foreground="{StaticResource Brush.Muted}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="قيد الانتظار">
                                                <Setter TargetName="Dot" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="DotHollow" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="مكتمل">
                                                <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Style="{StaticResource PlainLinkButton}"
                                    Command="{Binding ShowGuaranteeRequestsCommand}"
                                    automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Timeline.ShowAllRequests"
                                    automation:AutomationProperties.Name="عرض جميع الطلبات من الخط الزمني">
                                <TextBlock Text="انتقل إلى الطلبات الكاملة" FontSize="10.5" Foreground="{StaticResource Brush.Blue}" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border x:Name="AttachmentsAnchor"
                            Style="{StaticResource Card}"
                            Focusable="True"
                            Padding="12"
                            Margin="0,12,0,0"
                            Effect="{x:Null}"
                            automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Section.Attachments"
                            automation:AutomationProperties.Name="قسم المرفقات">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft">
                                    <TextBlock Text="الأدلة والمرفقات" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" VerticalAlignment="Center" />
                                    <Viewbox Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Path Data="{StaticResource Icon.Paperclip}" Stroke="{StaticResource Brush.Text}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Viewbox>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        CornerRadius="9"
                                        Padding="7,2"
                                        Background="#F8FAFC"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding OutputShortcutsSummaryText}"
                                               FontSize="9"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.Muted}" />
                                </Border>
                            </Grid>
                            <Border Height="1" Background="{StaticResource Brush.Border}" Margin="0,0,0,10" />
                            <TextBlock Text="{Binding AttachmentsSummaryText}"
                                       FontSize="10.4"
                                       Foreground="{StaticResource Brush.Muted}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10" />
                            <WrapPanel FlowDirection="RightToLeft" Margin="0,0,0,10" Visibility="Collapsed">
                                <WrapPanel.Style>
                                    <Style TargetType="WrapPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasOutputShortcuts}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </WrapPanel.Style>
                                <Button Command="{Binding OpenOutputLetterCommand}"
                                        CommandParameter="{Binding LatestLetterOutput}"
                                        Margin="0,0,10,6">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PlainLinkButton}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasLatestLetterOutput}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="أحدث خطاب طلب" FontSize="10.3" Foreground="{StaticResource Brush.Blue}" />
                                </Button>
                                <Button Command="{Binding OpenOutputResponseCommand}"
                                        CommandParameter="{Binding LatestResponseOutput}"
                                        Margin="0,0,0,6">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PlainLinkButton}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasLatestResponseOutput}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="أحدث رد بنك" FontSize="10.3" Foreground="{StaticResource Brush.Blue}" />
                                </Button>
                            </WrapPanel>
                            <TextBlock Text="{Binding OfficialAttachmentsHeading}"
                                       FontSize="10.8"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Text}"
                                       Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding Attachments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource PlainLinkButton}"
                                                Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="{Binding DocumentType}">
                                            <Grid Height="32" Margin="0,0,0,4" FlowDirection="LeftToRight">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="54" />
                                                    <ColumnDefinition Width="22" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Date}" FontSize="9.5" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center" FlowDirection="LeftToRight" />
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="10.5" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text}" VerticalAlignment="Center" Margin="8,0" FlowDirection="RightToLeft" />
                                                <TextBlock Grid.Column="2" Text="{Binding Size}" FontSize="10" Foreground="#4B5563" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                                <Border Grid.Column="3" Width="16" Height="18" CornerRadius="2" Background="#FEE2E2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileKind}" FontSize="5.5" FontWeight="Bold" Foreground="#DC2626"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Style="{StaticResource PlainLinkButton}"
                                    Command="{Binding ShowAllAttachmentsCommand}"
                                    Margin="0,8,0,0"
                                    Visibility="{Binding SelectedGuarantee.OpenAttachmentsAction.IsEnabled, Converter={StaticResource TrueToVisibleCollapsedConverter}}"
                                    IsEnabled="{Binding SelectedGuarantee.OpenAttachmentsAction.IsEnabled}"
                                    ToolTip="{Binding SelectedGuarantee.OpenAttachmentsAction.Hint}"
                                    ToolTipService.ShowOnDisabled="True"
                                    automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Attachments.ShowAll"
                                    automation:AutomationProperties.Name="عرض جميع المرفقات">
                                <TextBlock Text="عرض جميع المرفقات" FontSize="10.5" Foreground="{StaticResource Brush.Blue}" />
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border x:Name="ActionsAnchor"
                    Grid.Row="1"
                    Focusable="True"
                    Background="White"
                    BorderBrush="#E3E9F2"
                    BorderThickness="0,1,0,0"
                    Padding="12"
                    automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Section.Actions"
                    automation:AutomationProperties.Name="قسم الإجراءات السريعة">
                <StackPanel>
                    <TextBlock Text="القرار والعمل الآن" FontSize="12" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" Margin="0,0,0,9" />
                    <WrapPanel FlowDirection="RightToLeft">
                        <Button Style="{StaticResource BaseButton}"
                                Content="تعديل"
                                FontSize="9"
                                Margin="0,0,6,6"
                                Padding="2,0"
                                IsEnabled="{Binding SelectedGuarantee.EditAction.IsEnabled}"
                                ToolTip="{Binding SelectedGuarantee.EditAction.Hint}"
                                ToolTipService.ShowOnDisabled="True"
                                Command="{Binding EditGuaranteeCommand}"
                                CommandParameter="{Binding SelectedGuarantee}"
                                automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Action.Edit"
                                automation:AutomationProperties.Name="تعديل الضمان" />
                        <Button Style="{StaticResource BaseButton}"
                                Content="تمديد"
                                FontSize="9"
                                Margin="0,0,6,6"
                                Padding="2,0"
                                IsEnabled="{Binding SelectedGuarantee.ExtensionAction.IsEnabled}"
                                ToolTip="{Binding SelectedGuarantee.ExtensionAction.Hint}"
                                ToolTipService.ShowOnDisabled="True"
                                Command="{Binding CreateExtensionRequestCommand}"
                                CommandParameter="{Binding SelectedGuarantee}"
                                automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Action.Extension"
                                automation:AutomationProperties.Name="إنشاء طلب تمديد" />
                        <Button Style="{StaticResource BaseButton}"
                                BorderBrush="#97DBAE"
                                Background="#F5FFF7"
                                Foreground="#15803D"
                                Content="إفراج"
                                FontSize="9"
                                Margin="0,0,0,6"
                                Padding="2,0"
                                IsEnabled="{Binding SelectedGuarantee.ReleaseAction.IsEnabled}"
                                ToolTip="{Binding SelectedGuarantee.ReleaseAction.Hint}"
                                ToolTipService.ShowOnDisabled="True"
                                Command="{Binding CreateReleaseRequestCommand}"
                                CommandParameter="{Binding SelectedGuarantee}"
                                automation:AutomationProperties.AutomationId="GuaranteeDetailPanel.Action.Release"
                                automation:AutomationProperties.Name="إنشاء طلب إفراج" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
