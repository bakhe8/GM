<UserControl x:Class="GuaranteeManager.GuaranteesDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             automation:AutomationProperties.AutomationId="Guarantees.Workspace"
             automation:AutomationProperties.Name="مساحة الضمانات">

            <Grid Grid.Column="0" Margin="20" FlowDirection="RightToLeft">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MinHeight="40" MaxHeight="48" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" MinHeight="112" MaxHeight="128" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="118" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource NavButton.Active}"
                            Width="132"
                            Height="36"
                            Command="{Binding CreateNewGuaranteeCommand}"
                            automation:AutomationProperties.AutomationId="Guarantees.Toolbar.CreateNew"
                            automation:AutomationProperties.Name="إضافة ضمان">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="إضافة ضمان" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Viewbox Width="14" Height="14" Margin="7,0,0,0" VerticalAlignment="Center">
                                <Path Data="{StaticResource Icon.NewTransaction}" Stroke="White" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                        </StackPanel>
                    </Button>
                    <ComboBox Grid.Column="2"
                              Style="{StaticResource FilterComboBox}"
                              ItemsSource="{Binding TimeStatusOptions}"
                              SelectedItem="{Binding SelectedTimeStatus, Mode=TwoWay}"
                              DisplayMemberPath="Label"
                              automation:AutomationProperties.AutomationId="Guarantees.Filter.TimeStatus"
                              automation:AutomationProperties.Name="فلتر الحالة الزمنية" />
                    <ComboBox Grid.Column="4"
                              Style="{StaticResource FilterComboBox}"
                              ItemsSource="{Binding BankOptions}"
                              SelectedItem="{Binding SelectedBank, Mode=TwoWay}"
                              MinWidth="124"
                              Tag="{StaticResource Icon.Banks}"
                              automation:AutomationProperties.AutomationId="Guarantees.Filter.Bank"
                              automation:AutomationProperties.Name="فلتر البنك" />
                    <ComboBox Grid.Column="6"
                              Style="{StaticResource FilterComboBox}"
                              ItemsSource="{Binding GuaranteeTypeOptions}"
                              SelectedItem="{Binding SelectedGuaranteeType, Mode=TwoWay}"
                              MinWidth="112"
                              Tag="{StaticResource Icon.Guarantees}"
                              automation:AutomationProperties.AutomationId="Guarantees.Filter.Type"
                              automation:AutomationProperties.Name="فلتر نوع الضمان" />
                    <Border Grid.Column="8"
                            Background="White"
                            BorderBrush="#D8E1EE"
                            BorderThickness="1"
                            CornerRadius="6"
                            Height="36"
                            Padding="11,0">
                        <Grid FlowDirection="RightToLeft">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="GuaranteeSearchBox"
                                     Grid.Column="0"
                                     Style="{StaticResource SearchTextBox}"
                                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FlowDirection="RightToLeft"
                                     ToolTip="ابحث برقم الضمان، اسم المستفيد، رقم العقد..."
                                     automation:AutomationProperties.AutomationId="Guarantees.SearchBox"
                                     automation:AutomationProperties.Name="بحث الضمانات" />
                            <TextBlock Grid.Column="0"
                                       Text="ابحث برقم الضمان، اسم المستفيد، رقم العقد..."
                                       FontSize="11"
                                       Foreground="#94A3B8"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding Text, ElementName=GuaranteeSearchBox, Converter={StaticResource EmptyStringToVisibilityConverter}}" />
                            <Viewbox Grid.Column="1" Width="14" Height="14" Margin="8,0,0,0" VerticalAlignment="Center">
                                <Path Data="{StaticResource Icon.Search}" Stroke="#64748B" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}" Padding="16,12">
                        <Grid FlowDirection="LeftToRight">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" FlowDirection="RightToLeft" HorizontalAlignment="Center">
                                <TextBlock Text="طلبات معلقة" Style="{StaticResource KpiTitle}" Foreground="{StaticResource Brush.Orange}" />
                                <TextBlock Text="{Binding PendingRequestCount}" Style="{StaticResource KpiNumber}" Margin="0,2,0,0" />
                                <TextBlock Text="{Binding PendingRequestMeta}" Style="{StaticResource KpiMeta}" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="36" Height="36" CornerRadius="18" BorderBrush="{StaticResource Brush.Orange}" BorderThickness="1.5">
                                <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="{StaticResource Icon.History}" Stroke="{StaticResource Brush.Orange}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Viewbox>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}" Padding="16,12">
                        <Grid FlowDirection="LeftToRight">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" FlowDirection="RightToLeft" HorizontalAlignment="Center">
                                <TextBlock Text="منتهي" Style="{StaticResource KpiTitle}" Foreground="{StaticResource Brush.Red}" />
                                <TextBlock Text="{Binding ExpiredCount}" Style="{StaticResource KpiNumber}" Margin="0,2,0,0" />
                                <TextBlock Text="{Binding ExpiredMeta}" Style="{StaticResource KpiMeta}" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="36" Height="36" CornerRadius="18" BorderBrush="{StaticResource Brush.Red}" BorderThickness="1.5">
                                <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="{StaticResource Icon.Close}" Stroke="{StaticResource Brush.Red}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Viewbox>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource Card}" Padding="16,12">
                        <Grid FlowDirection="LeftToRight">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" FlowDirection="RightToLeft" HorizontalAlignment="Center">
                                <TextBlock Text="تحتاج متابعة" Style="{StaticResource KpiTitle}" Foreground="#C2410C" />
                                <TextBlock Text="{Binding ExpiredFollowUpCount}" Style="{StaticResource KpiNumber}" Margin="0,2,0,0" />
                                <TextBlock Text="{Binding ExpiredFollowUpMeta}" Style="{StaticResource KpiMeta}" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="36" Height="36" CornerRadius="18" BorderBrush="#FDBA74" BorderThickness="1.5">
                                <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="{StaticResource Icon.Notifications}" Stroke="#EA580C" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Viewbox>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="6" Style="{StaticResource Card}" Padding="16,12">
                        <Grid FlowDirection="LeftToRight">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" FlowDirection="RightToLeft" HorizontalAlignment="Center">
                                <TextBlock Text="قريب الانتهاء" Style="{StaticResource KpiTitle}" Foreground="{StaticResource Brush.Orange}" />
                                <TextBlock Text="{Binding ExpiringSoonCount}" Style="{StaticResource KpiNumber}" Margin="0,2,0,0" />
                                <TextBlock Text="{Binding ExpiringSoonMeta}" Style="{StaticResource KpiMeta}" />
                                <TextBlock Text="خلال 30 يوم" Style="{StaticResource KpiMeta}" Foreground="#F59E0B" FontWeight="SemiBold" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="36" Height="36" CornerRadius="18" BorderBrush="{StaticResource Brush.Orange}" BorderThickness="1.5">
                                <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="{StaticResource Icon.Calendar}" Stroke="{StaticResource Brush.Orange}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Viewbox>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="8" Style="{StaticResource Card}" Padding="16,12">
                        <Grid FlowDirection="LeftToRight">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" FlowDirection="RightToLeft" HorizontalAlignment="Center">
                                <TextBlock Text="نشط" Style="{StaticResource KpiTitle}" Foreground="{StaticResource Brush.Green}" />
                                <TextBlock Text="{Binding ActiveCount}" Style="{StaticResource KpiNumber}" Margin="0,2,0,0" />
                                <TextBlock Text="{Binding ActiveMeta}" Style="{StaticResource KpiMeta}" />
                            </StackPanel>
                            <Border Grid.Column="1" Width="36" Height="36" CornerRadius="18" BorderBrush="{StaticResource Brush.Green}" BorderThickness="1.5">
                                <Viewbox Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="{StaticResource Icon.Check}" Stroke="{StaticResource Brush.Green}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Viewbox>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="4" Style="{StaticResource ReferenceTableContainer}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="40" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Style="{StaticResource ReferenceTableHeaderBand}">
                            <Border Style="{StaticResource ReferenceTableHeaderDivider}" />
                            <Grid Margin="9,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.75*" />
                                    <ColumnDefinition Width="1.18*" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="1.00*" />
                                    <ColumnDefinition Width="1.00*" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="1.34*" />
                                    <ColumnDefinition Width="1.48*" />
                                    <ColumnDefinition Width="0.74*" />
                                    <ColumnDefinition Width="1.30*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="الإجراءات" Style="{StaticResource TableHeaderText}" />
                                <TextBlock Grid.Column="1" Text="الحالة التشغيلية" Style="{StaticResource TableHeaderText}" />
                                <TextBlock Grid.Column="2" Text="حالة الوقت" Style="{StaticResource TableHeaderText}" />
                                <TextBlock Grid.Column="3" Text="تاريخ الانتهاء" Style="{StaticResource TableHeaderText}" />
                                <TextBlock Grid.Column="4" Text="تاريخ الإصدار" Style="{StaticResource TableHeaderText}" />
                                <TextBlock Grid.Column="5" Text="المبلغ" Style="{StaticResource TableHeaderText}" />
                                <TextBlock Grid.Column="6" Text="البنك" Style="{StaticResource TableHeaderRight}" />
                                <TextBlock Grid.Column="7" Text="اسم المستفيد" Style="{StaticResource TableHeaderRight}" />
                                <TextBlock Grid.Column="8" Text="الإصدار" Style="{StaticResource TableHeaderText}" />
                                <TextBlock Grid.Column="9" Text="رقم الضمان" Style="{StaticResource TableHeaderRight}" />
                            </Grid>
                        </Grid>

                        <ListBox Grid.Row="1"
                                 Style="{StaticResource ReferenceTableRowsListBox}"
                                 ItemsSource="{Binding Guarantees}"
                                 SelectedItem="{Binding SelectedTableGuarantee, Mode=TwoWay}"
                                 automation:AutomationProperties.AutomationId="Guarantees.Table.List"
                                 automation:AutomationProperties.Name="قائمة الضمانات">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource ReferenceTableRowItem}">
                                    <Setter Property="automation:AutomationProperties.Name" Value="{Binding RowAutomationName}" />
                                    <Setter Property="automation:AutomationProperties.ItemStatus" Value="{Binding GuaranteeNo}" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel FlowDirection="LeftToRight">
                                    <Grid Height="40"
                                          Margin="6,0"
                                          FlowDirection="LeftToRight"
                                          Cursor="Hand"
                                          ToolTip="عرض بيانات الضمان الحالي في اللوحة الجانبية">
                                        <Grid.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.SelectGuaranteeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}" />
                                        </Grid.InputBindings>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.75*" />
                                            <ColumnDefinition Width="1.18*" />
                                            <ColumnDefinition Width="1.15*" />
                                            <ColumnDefinition Width="1.00*" />
                                            <ColumnDefinition Width="1.00*" />
                                            <ColumnDefinition Width="1.15*" />
                                            <ColumnDefinition Width="1.34*" />
                                            <ColumnDefinition Width="1.48*" />
                                            <ColumnDefinition Width="0.74*" />
                                            <ColumnDefinition Width="1.30*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                            <Button Style="{StaticResource PrimaryButton}"
                                                    Height="26"
                                                    MinWidth="70"
                                                    Padding="7,0"
                                                    FontSize="9.5"
                                                    Margin="0,0,4,0"
                                                    ToolTip="يعرض طلبات هذا الضمان فقط في شاشة الطلبات"
                                                    ToolTipService.ShowOnDisabled="True"
                                                    Command="{Binding DataContext.ShowRowRequestsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    automation:AutomationProperties.AutomationId="{Binding RowRequestsAutomationId}"
                                                    automation:AutomationProperties.Name="{Binding RowRequestsAutomationName}"
                                                    automation:AutomationProperties.HelpText="يعرض طلبات هذا الضمان فقط في شاشة الطلبات."
                                                    automation:AutomationProperties.ItemStatus="{Binding GuaranteeNo}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Viewbox Width="10" Height="10" Margin="0,0,3,0" VerticalAlignment="Center">
                                                        <Path Data="{StaticResource Icon.Requests}" Stroke="White" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    </Viewbox>
                                                    <TextBlock Text="الطلبات" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding WorkStatus}"
                                                   Style="{StaticResource TableCellCenter}"
                                                   FontSize="9.5"
                                                   Foreground="{Binding WorkBrush}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TimeStatus}"
                                                   Style="{StaticResource TableCellCenter}"
                                                   FontSize="9.5"
                                                   Foreground="{Binding TimeBrush}" />
                                        <TextBlock Grid.Column="3" Text="{Binding ExpiryDate}" Style="{StaticResource TableCellCenter}" />
                                        <TextBlock Grid.Column="4" Text="{Binding IssueDate}" Style="{StaticResource TableCellCenter}" />
                                        <TextBlock Grid.Column="5" Text="{Binding Amount}" Style="{StaticResource TableCellCenter}" />
                                        <StackPanel Grid.Column="6" Orientation="Horizontal" FlowDirection="RightToLeft" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <Image Source="{Binding BankLogo}" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality" />
                                            <Border Width="8" />
                                            <TextBlock Text="{Binding Bank}" Style="{StaticResource TableCellText}" TextAlignment="Right" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="7" Text="{Binding Beneficiary}" Style="{StaticResource TableCellRight}" />
                                        <TextBlock Grid.Column="8" Text="{Binding VersionLabel}" Style="{StaticResource TableCellCenter}" />
                                        <TextBlock Grid.Column="9" Text="{Binding GuaranteeNo}" Style="{StaticResource TableCellRight}" />
                                    </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="2" Style="{StaticResource ReferenceTablePager}">
                             <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                  <Button Style="{StaticResource ReferenceTablePagerButton}"
                                          Content="←"
                                          Command="{Binding PreviousGuaranteePageCommand}"
                                          automation:AutomationProperties.AutomationId="Guarantees.Pager.Previous"
                                          automation:AutomationProperties.Name="الصفحة السابقة" />
                                  <ItemsControl ItemsSource="{Binding GuaranteePagerButtons}">
                                      <ItemsControl.ItemsPanel>
                                          <ItemsPanelTemplate>
                                              <StackPanel Orientation="Horizontal" />
                                          </ItemsPanelTemplate>
                                      </ItemsControl.ItemsPanel>
                                      <ItemsControl.ItemTemplate>
                                          <DataTemplate>
                                              <Button Content="{Binding Label}"
                                                      Command="{Binding DataContext.GoToGuaranteePageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding PageNumber}"
                                                      Margin="6,0,0,0"
                                                      automation:AutomationProperties.AutomationId="{Binding AutomationId}"
                                                      automation:AutomationProperties.Name="{Binding AutomationName}">
                                                  <Button.Style>
                                                      <Style TargetType="Button" BasedOn="{StaticResource ReferenceTablePagerButton}">
                                                          <Style.Triggers>
                                                              <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                  <Setter Property="Background" Value="#2563EB" />
                                                                  <Setter Property="Foreground" Value="White" />
                                                                  <Setter Property="BorderThickness" Value="0" />
                                                              </DataTrigger>
                                                          </Style.Triggers>
                                                      </Style>
                                                  </Button.Style>
                                              </Button>
                                          </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                  <Button Style="{StaticResource ReferenceTablePagerButton}"
                                          Content="→"
                                          Margin="6,0,0,0"
                                          Command="{Binding NextGuaranteePageCommand}"
                                          automation:AutomationProperties.AutomationId="Guarantees.Pager.Next"
                                          automation:AutomationProperties.Name="الصفحة التالية" />
                                  <Button Style="{StaticResource ReferenceTablePagerButton}"
                                          Content="{Binding GuaranteePageSizeText}"
                                          IsEnabled="False"
                                          MinWidth="46"
                                          Margin="12,0,0,0" />
                                 <TextBlock Text="لكل صفحة" FontSize="11" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center" Margin="8,0,0,0" />
                             </StackPanel>
                            <TextBlock Text="{Binding FooterSummary}"
                                       Style="{StaticResource ReferenceTableFooterSummary}" />
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="6" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource Card}" Padding="14">
                        <Grid FlowDirection="LeftToRight">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Viewbox Width="54" Height="54" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Data="{StaticResource Icon.ShieldLock}" Stroke="#3B82F6" StrokeThickness="1.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.8" />
                            </Viewbox>
                            <StackPanel Grid.Column="1" FlowDirection="RightToLeft" HorizontalAlignment="Right">
                                <TextBlock Text="دليل الاستخدام الذكي" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" TextAlignment="Right" />
                                <TextBlock FontSize="11.4" Margin="0,7,0,0" TextAlignment="Right">
                                    <Run Text="• " Foreground="#60A5FA" FontWeight="Bold" />
                                    <Run Text="استخدم التصفية للوصول السريع للضمانات المطلوبة." Foreground="#374151" />
                                </TextBlock>
                                <TextBlock FontSize="11.4" Margin="0,5,0,0" TextAlignment="Right">
                                    <Run Text="• " Foreground="#60A5FA" FontWeight="Bold" />
                                    <Run Text="تابع الضمانات القريبة من الانتهاء واتخذ الإجراء المناسب." Foreground="#374151" />
                                </TextBlock>
                                <TextBlock Text="عرض المزيد من النصائح" FontSize="11" Foreground="{StaticResource Brush.Blue}" Margin="0,10,0,0" TextAlignment="Right" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource Card}" Padding="14">
                        <Grid FlowDirection="LeftToRight">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0" Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Data="{StaticResource Icon.Lightbulb}" Stroke="#EAB308" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                            <StackPanel Grid.Column="1" FlowDirection="RightToLeft" HorizontalAlignment="Right">
                                <TextBlock Text="توصيات تشغيلية" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Brush.Text}" TextAlignment="Right" />
                                <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                                    <Viewbox Width="10" Height="10" Margin="0,0,6,0">
                                        <Path Data="{StaticResource Icon.Check}" Stroke="#10B981" StrokeThickness="3" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Viewbox>
                                    <TextBlock Text="يوجد 15 ضمانًا قريب الانتهاء خلال 30 يوم." FontSize="11.6" Foreground="#374151" TextAlignment="Right" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <Viewbox Width="10" Height="10" Margin="0,0,6,0">
                                        <Path Data="{StaticResource Icon.Check}" Stroke="#10B981" StrokeThickness="3" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Viewbox>
                                    <TextBlock Text="يوجد 8 طلبات معلقة تحتاج إلى متابعة." FontSize="11.6" Foreground="#374151" TextAlignment="Right" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <Viewbox Width="10" Height="10" Margin="0,0,6,0">
                                        <Path Data="{StaticResource Icon.Check}" Stroke="#10B981" StrokeThickness="3" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Viewbox>
                                    <TextBlock Text="يوصى بمراجعة الضمانات منتهية الصلاحية." FontSize="11.6" Foreground="#374151" TextAlignment="Right" />
                                </StackPanel>
                                <TextBlock Text="عرض جميع التوصيات" FontSize="11" Foreground="{StaticResource Brush.Blue}" Margin="0,10,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
</UserControl>
