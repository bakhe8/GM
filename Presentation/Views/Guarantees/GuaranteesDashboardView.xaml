<UserControl x:Class="GuaranteeManager.GuaranteesDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             automation:AutomationProperties.AutomationId="Guarantees.Workspace"
             automation:AutomationProperties.Name="مساحة الضمانات">

            <Grid Grid.Column="0" Margin="20" FlowDirection="RightToLeft">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MinHeight="40" MaxHeight="48" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" MinHeight="112" MaxHeight="128" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource NavButton.Active}"
                            Width="132"
                            Height="36"
                            Command="{Binding CreateNewGuaranteeCommand}"
                            automation:AutomationProperties.AutomationId="Guarantees.Toolbar.CreateNew"
                            automation:AutomationProperties.Name="إضافة ضمان">
                        <StackPanel Orientation="Horizontal" FlowDirection="RightToLeft"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="إضافة ضمان" FontSize="12" FontWeight="Medium" VerticalAlignment="Center" />
                            <Viewbox Width="14" Height="14" Margin="7,0,0,0" VerticalAlignment="Center">
                                <Path Data="{StaticResource Icon.NewTransaction}" Stroke="White" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                        </StackPanel>
                    </Button>
                    <ComboBox Grid.Column="2"
                              Style="{StaticResource FilterComboBox}"
                              ItemsSource="{Binding BankOptions}"
                              SelectedItem="{Binding SelectedBank, Mode=TwoWay}"
                              MinWidth="124"
                              Tag="{StaticResource Icon.Banks}"
                              automation:AutomationProperties.AutomationId="Guarantees.Filter.Bank"
                              automation:AutomationProperties.Name="فلتر البنك">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            FlowDirection="RightToLeft"
                                            HorizontalAlignment="Right">
                                    <Image Source="{Binding Converter={StaticResource BankLogoSourceConverter}}"
                                           Width="16"
                                           Height="16"
                                           Margin="0,0,7,0"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Source, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox Grid.Column="4"
                              Style="{StaticResource FilterComboBox}"
                              ItemsSource="{Binding GuaranteeTypeOptions}"
                              SelectedItem="{Binding SelectedGuaranteeType, Mode=TwoWay}"
                              MinWidth="112"
                              Tag="{StaticResource Icon.Guarantees}"
                              automation:AutomationProperties.AutomationId="Guarantees.Filter.Type"
                              automation:AutomationProperties.Name="فلتر نوع الضمان" />
                    <Border Grid.Column="6"
                            Background="White"
                            BorderBrush="#D8E1EE"
                            BorderThickness="1"
                            CornerRadius="6"
                            Height="36"
                            Padding="11,0">
                        <Grid FlowDirection="RightToLeft">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="GuaranteeSearchBox"
                                     Grid.Column="0"
                                     Style="{StaticResource SearchTextBox}"
                                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FlowDirection="RightToLeft"
                                     ToolTip="ابحث برقم الضمان، اسم المورد، رقم العقد..."
                                     automation:AutomationProperties.AutomationId="Guarantees.SearchBox"
                                     automation:AutomationProperties.Name="بحث الضمانات" />
                            <TextBlock Grid.Column="0"
                                      Text="ابحث برقم الضمان، اسم المورد، رقم العقد..."
                                       FontSize="11"
                                       Foreground="{StaticResource Brush.Text.Muted}"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding Text, ElementName=GuaranteeSearchBox, Converter={StaticResource EmptyStringToVisibilityConverter}}" />
                            <Viewbox Grid.Column="1" Width="14" Height="14" Margin="8,0,0,0" VerticalAlignment="Center">
                                <Path Data="{StaticResource Icon.Search}" Stroke="{StaticResource Brush.Text.Secondary}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="16,12"
                            MinHeight="84"
                            Cursor="Hand"
                            ToolTip="عرض الضمانات المنتهية أو المغلقة"
                            automation:AutomationProperties.AutomationId="Guarantees.FilterCard.Expired"
                            automation:AutomationProperties.Name="فلتر الضمانات المنتهية أو المغلقة">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                <Setter Property="BorderThickness" Value="2" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpiredGuaranteeFilterSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="#EF4444" />
                                        <Setter Property="Background" Value="#F8FBFF" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding ApplyGuaranteeStatusFilterCommand}"
                                          CommandParameter="Expired" />
                        </Border.InputBindings>
                        <StackPanel FlowDirection="RightToLeft" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="ضمانات منتهية" Style="{StaticResource KpiTitle}" Foreground="{StaticResource Brush.Danger}" />
                            <TextBlock Text="{Binding ExpiredCount}" Style="{StaticResource KpiNumber}" Margin="0,2,0,0" />
                            <TextBlock Text="{Binding ExpiredMeta}" Style="{StaticResource KpiMeta}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="16,12"
                            MinHeight="84"
                            Cursor="Hand"
                            ToolTip="عرض الضمانات التي تحتاج متابعة"
                            automation:AutomationProperties.AutomationId="Guarantees.FilterCard.NeedsFollowUp"
                            automation:AutomationProperties.Name="فلتر الضمانات التي تحتاج متابعة">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                <Setter Property="BorderThickness" Value="2" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNeedsFollowUpGuaranteeFilterSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="#E09408" />
                                        <Setter Property="Background" Value="#F8FBFF" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding ApplyGuaranteeStatusFilterCommand}"
                                          CommandParameter="NeedsFollowUp" />
                        </Border.InputBindings>
                        <StackPanel FlowDirection="RightToLeft" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="تحتاج متابعة" Style="{StaticResource KpiTitle}" Foreground="{StaticResource Brush.Warning}" />
                            <TextBlock Text="{Binding ExpiredFollowUpCount}" Style="{StaticResource KpiNumber}" Margin="0,2,0,0" />
                            <TextBlock Text="{Binding ExpiredFollowUpMeta}" Style="{StaticResource KpiMeta}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4"
                            Padding="16,12"
                            MinHeight="84"
                            Cursor="Hand"
                            ToolTip="عرض الضمانات قريبة الانتهاء"
                            automation:AutomationProperties.AutomationId="Guarantees.FilterCard.ExpiringSoon"
                            automation:AutomationProperties.Name="فلتر الضمانات قريبة الانتهاء">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                <Setter Property="BorderThickness" Value="2" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpiringSoonGuaranteeFilterSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="#E09408" />
                                        <Setter Property="Background" Value="#F8FBFF" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding ApplyGuaranteeStatusFilterCommand}"
                                          CommandParameter="ExpiringSoon" />
                        </Border.InputBindings>
                        <StackPanel FlowDirection="RightToLeft" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="قريب الانتهاء" Style="{StaticResource KpiTitle}" Foreground="{StaticResource Brush.Orange}" />
                            <TextBlock Text="{Binding ExpiringSoonCount}" Style="{StaticResource KpiNumber}" Margin="0,2,0,0" />
                            <TextBlock Text="{Binding ExpiringSoonMeta}" Style="{StaticResource KpiMeta}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="6"
                            Padding="16,12"
                            MinHeight="84"
                            Cursor="Hand"
                            ToolTip="عرض الضمانات النشطة"
                            automation:AutomationProperties.AutomationId="Guarantees.FilterCard.Active"
                            automation:AutomationProperties.Name="فلتر الضمانات النشطة">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                <Setter Property="BorderThickness" Value="2" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActiveGuaranteeFilterSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="#16A34A" />
                                        <Setter Property="Background" Value="#F8FBFF" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding ApplyGuaranteeStatusFilterCommand}"
                                          CommandParameter="Active" />
                        </Border.InputBindings>
                        <StackPanel FlowDirection="RightToLeft" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="نشط" Style="{StaticResource KpiTitle}" Foreground="{StaticResource Brush.Green}" />
                            <TextBlock Text="{Binding ActiveCount}" Style="{StaticResource KpiNumber}" Margin="0,2,0,0" />
                            <TextBlock Text="{Binding ActiveMeta}" Style="{StaticResource KpiMeta}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="4" Style="{StaticResource ReferenceTableContainer}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="40" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Style="{StaticResource ReferenceTableHeaderBand}">
                            <Border Style="{StaticResource ReferenceTableHeaderDivider}" />
                            <Grid Margin="9,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.05*" />
                                    <ColumnDefinition Width="0.95*" />
                                    <ColumnDefinition Width="1.00*" />
                                    <ColumnDefinition Width="1.00*" />
                                    <ColumnDefinition Width="1.15*" />
                                    <ColumnDefinition Width="1.65*" />
                                    <ColumnDefinition Width="2.55*" />
                                    <ColumnDefinition Width="1.47*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="الحالة التشغيلية" Style="{StaticResource TableHeaderText}" />
                                <TextBlock Grid.Column="1" Text="حالة الوقت" Style="{StaticResource TableHeaderText}" />
                                <TextBlock Grid.Column="2" Text="تاريخ الانتهاء" Style="{StaticResource TableHeaderText}" />
                                <TextBlock Grid.Column="3" Text="تاريخ الإصدار" Style="{StaticResource TableHeaderText}" />
                                <TextBlock Grid.Column="4" Text="المبلغ" Style="{StaticResource TableHeaderRight}" />
                                <TextBlock Grid.Column="5" Text="البنك" Style="{StaticResource TableHeaderRight}" />
                                <TextBlock Grid.Column="6" Text="المورد" Style="{StaticResource TableHeaderRight}" />
                                <TextBlock Grid.Column="7" Text="رقم الضمان" Style="{StaticResource TableHeaderRight}" />
                            </Grid>
                        </Grid>

                        <ListBox Grid.Row="1"
                                 Style="{StaticResource ReferenceTableRowsListBox}"
                                 ItemsSource="{Binding Guarantees}"
                                 SelectedItem="{Binding SelectedTableGuarantee, Mode=TwoWay}"
                                 automation:AutomationProperties.AutomationId="Guarantees.Table.List"
                                 automation:AutomationProperties.Name="قائمة الضمانات">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource ReferenceTableRowItem}">
                                    <Setter Property="automation:AutomationProperties.Name" Value="{Binding RowAutomationName}" />
                                    <Setter Property="automation:AutomationProperties.ItemStatus" Value="{Binding GuaranteeNo}" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel FlowDirection="LeftToRight">
                                    <Grid Height="40"
                                          Margin="6,0"
                                          FlowDirection="LeftToRight"
                                          Cursor="Hand"
                                          ToolTip="عرض بيانات الضمان الحالي في اللوحة الجانبية">
                                        <Grid.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.SelectGuaranteeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}" />
                                        </Grid.InputBindings>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.05*" />
                                            <ColumnDefinition Width="0.95*" />
                                            <ColumnDefinition Width="1.00*" />
                                            <ColumnDefinition Width="1.00*" />
                                            <ColumnDefinition Width="1.15*" />
                                            <ColumnDefinition Width="1.65*" />
                                            <ColumnDefinition Width="2.55*" />
                                            <ColumnDefinition Width="1.47*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding WorkStatus}"
                                                   Style="{StaticResource TableCellCenter}"
                                                   FontSize="10"
                                                   Foreground="{Binding WorkBrush}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TimeStatus}"
                                                   Style="{StaticResource TableCellCenter}"
                                                   FontSize="10"
                                                   Foreground="{Binding TimeBrush}" />
                                        <TextBlock Grid.Column="2" Text="{Binding ExpiryDate}" Style="{StaticResource TableCellCenter}" />
                                        <TextBlock Grid.Column="3" Text="{Binding IssueDate}" Style="{StaticResource TableCellCenter}" />
                                        <TextBlock Grid.Column="4" Text="{Binding Amount}" Style="{StaticResource TableAmountCell}" />
                                        <Grid Grid.Column="5"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              ClipToBounds="True">
                                            <Grid FlowDirection="RightToLeft"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="7" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Image Grid.Column="0"
                                                       Source="{Binding BankLogo}"
                                                       Width="16"
                                                       Height="16"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Bank}"
                                                           Style="{StaticResource TableCellRight}"
                                                           MaxWidth="118"
                                                           HorizontalAlignment="Right"
                                                           TextAlignment="Right" />
                                            </Grid>
                                        </Grid>
                                        <TextBlock Grid.Column="6" Text="{Binding Supplier}" Style="{StaticResource TableCellRight}" />
                                        <TextBlock Grid.Column="7" Text="{Binding GuaranteeNo}" Style="{StaticResource TableCellRight}" />
                                    </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="2" Style="{StaticResource ReferenceTablePager}">
                             <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                  <Button Style="{StaticResource ReferenceTablePagerButton}"
                                          Content="←"
                                          Command="{Binding PreviousGuaranteePageCommand}"
                                          automation:AutomationProperties.AutomationId="Guarantees.Pager.Previous"
                                          automation:AutomationProperties.Name="الصفحة السابقة" />
                                  <ItemsControl ItemsSource="{Binding GuaranteePagerButtons}">
                                      <ItemsControl.ItemsPanel>
                                          <ItemsPanelTemplate>
                                              <StackPanel Orientation="Horizontal" />
                                          </ItemsPanelTemplate>
                                      </ItemsControl.ItemsPanel>
                                      <ItemsControl.ItemTemplate>
                                          <DataTemplate>
                                              <Button Content="{Binding Label}"
                                                      Command="{Binding DataContext.GoToGuaranteePageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding PageNumber}"
                                                      Margin="6,0,0,0"
                                                      automation:AutomationProperties.AutomationId="{Binding AutomationId}"
                                                      automation:AutomationProperties.Name="{Binding AutomationName}">
                                                  <Button.Style>
                                                      <Style TargetType="Button" BasedOn="{StaticResource ReferenceTablePagerButton}">
                                                          <Style.Triggers>
                                                              <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                  <Setter Property="Background" Value="{StaticResource Brush.Primary}" />
                                                                  <Setter Property="Foreground" Value="{StaticResource Brush.Text.OnPrimary}" />
                                                                  <Setter Property="BorderThickness" Value="0" />
                                                              </DataTrigger>
                                                          </Style.Triggers>
                                                      </Style>
                                                  </Button.Style>
                                              </Button>
                                          </DataTemplate>
                                      </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                  <Button Style="{StaticResource ReferenceTablePagerButton}"
                                          Content="→"
                                          Margin="6,0,0,0"
                                          Command="{Binding NextGuaranteePageCommand}"
                                          automation:AutomationProperties.AutomationId="Guarantees.Pager.Next"
                                          automation:AutomationProperties.Name="الصفحة التالية" />
                                  <Button Style="{StaticResource ReferenceTablePagerButton}"
                                          Content="{Binding GuaranteePageSizeText}"
                                          IsEnabled="False"
                                          MinWidth="46"
                                          Margin="12,0,0,0" />
                                 <TextBlock Text="لكل صفحة" FontSize="11" Foreground="{StaticResource Brush.Muted}" VerticalAlignment="Center" Margin="8,0,0,0" />
                             </StackPanel>
                            <TextBlock Text="{Binding FooterSummary}"
                                       Style="{StaticResource ReferenceTableFooterSummary}" />
                        </Grid>
                    </Grid>
                </Border>

            </Grid>
</UserControl>
